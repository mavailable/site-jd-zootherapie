# Copier en .env et remplir les valeurs

SITE_URL=https://jd-zootherapie.fr

# Web3Forms — formulaire de contact
WEB3FORMS_KEY=votre-cle-web3forms

# Umami Analytics (créé lors du déploiement wf-10)
