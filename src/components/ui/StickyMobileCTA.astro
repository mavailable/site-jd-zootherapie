---
import { business } from '@data/business';
---

<!-- Sticky CTA mobile only -->
<div class="fixed bottom-0 left-0 right-0 z-30 md:hidden bg-white border-t border-neutral-200 px-4 py-3 pb-[max(0.75rem,env(safe-area-inset-bottom))]">
  <div class="flex gap-3">
    <a href={`tel:${business.phone}`}
       class="flex-1 inline-flex items-center justify-center gap-2 bg-accent-700 text-white py-3 rounded font-semibold text-sm hover:bg-accent-800 transition-colors min-h-[44px]"
       aria-label="Appeler Jennifer De Groeve">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      Appeler
    </a>
    <a href="#contact"
       class="flex-1 inline-flex items-center justify-center gap-2 border-2 border-primary-600 text-primary-700 py-3 rounded font-semibold text-sm hover:bg-primary-600 hover:text-white transition-colors min-h-[44px]">
      Me contacter
    </a>
  </div>
</div>
