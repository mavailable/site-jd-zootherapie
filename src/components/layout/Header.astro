---
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();

const navLinks = [
  { label: 'La zoothérapie', href: '/zootherapie' },
  { label: 'Les ateliers', href: '/ateliers' },
  { label: 'Mon parcours', href: '/a-propos' },
  { label: 'Blog', href: '/blog' },
  { label: 'Tarifs', href: '/tarifs' },
  { label: 'Contact', href: '/contact' },
];

// Détecte la page active pour le surlignage nav
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-40 bg-white/95 backdrop-blur-sm border-b border-neutral-200">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Navigation principale">
    <div class="flex items-center justify-between h-16 md:h-20">

      <!-- Logo -->
      <a href="/"
         class="flex items-center gap-2.5 text-primary-900 font-heading font-bold text-lg md:text-xl"
         aria-label="JD Zoothérapie — Retour à l'accueil">
        <img
          src="/images/logo-sm.webp"
          alt="JD Zoothérapie"
          class="h-11 w-11 object-contain shrink-0"
          width="44"
          height="44"
          loading="eager"
          decoding="async"
        />
        <span class="hidden sm:block leading-tight text-primary-900">Zoothérapie</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-3 py-2 rounded text-sm font-medium transition-colors ${
              currentPath === link.href
                ? 'text-primary-700 bg-primary-50'
                : 'text-neutral-700 hover:text-primary-600 hover:bg-neutral-50'
            }`}
          >
            {link.label}
          </a>
        ))}
        <a
          href="https://cal.eu/jdzootherapie/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="ml-3 inline-flex items-center gap-2 bg-accent-700 text-white px-5 py-2.5 rounded font-semibold text-sm hover:bg-accent-800 transition-colors min-h-[44px]"
          aria-label="Prendre rendez-vous avec Jennifer"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Prendre RDV
        </a>
      </div>

      <!-- Mobile: phone + hamburger -->
      <div class="flex items-center gap-2 md:hidden">
        <a
          href={`tel:${siteInfo.phone}`}
          class="inline-flex items-center justify-center w-10 h-10 bg-accent-700 text-white rounded-full hover:bg-accent-800 transition-colors"
          aria-label={`Appeler ${siteInfo.name}`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </a>
        <button
          id="mobile-menu-btn"
          class="inline-flex items-center justify-center w-10 h-10 text-neutral-700 hover:text-primary-600 transition-colors"
          aria-label="Ouvrir le menu de navigation"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="menu-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
          <svg id="menu-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4 border-t border-neutral-100" role="navigation" aria-label="Menu mobile">
      <div class="flex flex-col gap-1 pt-3">
        <a href="/" class="mobile-nav-link block px-3 py-3 text-neutral-700 hover:text-primary-600 hover:bg-primary-50 rounded transition-colors font-medium text-sm">
          Accueil
        </a>
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`mobile-nav-link block px-3 py-3 rounded transition-colors font-medium text-sm ${
              currentPath === link.href
                ? 'text-primary-700 bg-primary-50'
                : 'text-neutral-700 hover:text-primary-600 hover:bg-primary-50'
            }`}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<!-- Spacer for fixed header -->
<div class="h-16 md:h-20" aria-hidden="true"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
      btn.setAttribute('aria-label', isOpen ? 'Ouvrir le menu de navigation' : 'Fermer le menu de navigation');
    });

    menu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Ouvrir le menu de navigation');
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        iconOpen.classList.remove('hidden');
        iconClose.classList.add('hidden');
        btn.setAttribute('aria-expanded', 'false');
        btn.setAttribute('aria-label', 'Ouvrir le menu de navigation');
        btn.focus();
      }
    });
  }
</script>
