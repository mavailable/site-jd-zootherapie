---
/**
 * ConsentBanner.astro
 *
 * Banniere cookies CNIL-compliant pour sites avec tracking publicitaire (Google Ads).
 * Pilote Consent Mode v2 (granular: ad_storage, ad_user_data, ad_personalization,
 * analytics_storage).
 *
 * Comportement :
 * - Aucun tracking avant choix explicite (defaults all 'denied').
 * - Apparait 1.5s apres chargement (le visiteur voit le hero d'abord).
 * - 3 boutons visuellement equivalents (Refuser / Personnaliser / Accepter).
 * - Choix memorise 13 mois (localStorage + cookie 1st-party).
 * - Lien "Gerer mes cookies" doit etre ajoute au footer pour rappel du choix.
 *
 * Injecte uniquement si business.ads.enabled = true (cf. BaseLayout).
 */
---

<div id="consent-banner" class="consent-banner" role="region" aria-label="Gestion des cookies" hidden>
  <div class="consent-inner">
    <p class="consent-text">
      Ce site utilise des cookies pour mesurer l'efficacite de nos campagnes publicitaires.
      Vous pouvez accepter, refuser ou personnaliser vos choix a tout moment.
    </p>
    <div class="consent-actions">
      <button type="button" class="consent-btn consent-btn--ghost" data-consent-action="refuse">
        Refuser
      </button>
      <button type="button" class="consent-btn consent-btn--ghost" data-consent-action="customize">
        Personnaliser
      </button>
      <button type="button" class="consent-btn consent-btn--primary" data-consent-action="accept">
        Accepter
      </button>
    </div>
  </div>
</div>

<div id="consent-modal" class="consent-modal" role="dialog" aria-modal="true" aria-labelledby="consent-modal-title" hidden>
  <div class="consent-modal-backdrop" data-consent-close></div>
  <div class="consent-modal-box">
    <h2 id="consent-modal-title" class="consent-modal-title">Personnaliser mes cookies</h2>

    <div class="consent-category">
      <div class="consent-category-header">
        <h3>Mesure d'audience</h3>
        <span class="consent-category-status consent-category-status--always">Toujours actif</span>
      </div>
      <p>Mesure anonyme du trafic (Umami, sans cookies). Nous aide a comprendre comment le site est utilise, sans suivre individuellement les visiteurs.</p>
    </div>

    <div class="consent-category">
      <div class="consent-category-header">
        <h3>Publicite et mesure publicitaire</h3>
        <label class="consent-toggle">
          <input type="checkbox" id="consent-ads-toggle" />
          <span class="consent-toggle-slider" aria-hidden="true"></span>
          <span class="sr-only">Activer les cookies publicitaires</span>
        </label>
      </div>
      <p>Cookies Google Ads pour mesurer les conversions depuis les campagnes publicitaires et eviter de vous montrer la meme annonce plusieurs fois.</p>
    </div>

    <div class="consent-modal-actions">
      <button type="button" class="consent-btn consent-btn--ghost" data-consent-close>Annuler</button>
      <button type="button" class="consent-btn consent-btn--primary" data-consent-action="save-custom">Enregistrer mes choix</button>
    </div>
  </div>
</div>

<style>
  .consent-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0.875rem 1rem;
    background: rgba(17, 24, 39, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: rgba(255, 255, 255, 0.95);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.35s ease, transform 0.35s ease;
  }
  .consent-banner[data-visible] {
    opacity: 1;
    transform: translateY(0);
  }
  .consent-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: stretch;
  }
  @media (min-width: 768px) {
    .consent-inner {
      flex-direction: row;
      align-items: center;
      gap: 1.25rem;
    }
  }
  .consent-text {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
  }
  .consent-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .consent-btn {
    padding: 0.5rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 6px;
    background: transparent;
    color: rgba(255, 255, 255, 0.95);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    min-height: 40px;
    min-width: 96px;
    font-family: inherit;
  }
  .consent-btn--ghost:hover,
  .consent-btn--ghost:focus-visible {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.55);
    outline: none;
  }
  .consent-btn--primary {
    background: rgba(255, 255, 255, 0.95);
    color: #111827;
    border-color: rgba(255, 255, 255, 0.95);
  }
  .consent-btn--primary:hover,
  .consent-btn--primary:focus-visible {
    background: white;
    outline: 2px solid rgba(255, 255, 255, 0.5);
    outline-offset: 2px;
  }

  /* Modal */
  .consent-modal {
    position: fixed;
    inset: 0;
    z-index: 110;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .consent-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }
  .consent-modal-box {
    position: relative;
    background: white;
    color: #111827;
    max-width: 520px;
    width: 100%;
    border-radius: 12px;
    padding: 1.5rem;
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  .consent-modal-title {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    font-weight: 600;
  }
  .consent-category {
    padding: 0.875rem 0;
    border-top: 1px solid #e5e7eb;
  }
  .consent-category:first-of-type { border-top: none; }
  .consent-category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.35rem;
  }
  .consent-category-header h3 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .consent-category p {
    margin: 0;
    font-size: 0.825rem;
    color: #6b7280;
    line-height: 1.5;
  }
  .consent-category-status--always {
    font-size: 0.75rem;
    color: #059669;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    background: #d1fae5;
    border-radius: 4px;
  }
  .consent-toggle {
    position: relative;
    display: inline-block;
    width: 42px;
    height: 24px;
    cursor: pointer;
  }
  .consent-toggle input { position: absolute; opacity: 0; width: 0; height: 0; }
  .consent-toggle-slider {
    position: absolute;
    inset: 0;
    background: #d1d5db;
    border-radius: 24px;
    transition: background 0.2s ease;
  }
  .consent-toggle-slider::before {
    content: '';
    position: absolute;
    left: 3px;
    top: 3px;
    width: 18px;
    height: 18px;
    background: white;
    border-radius: 50%;
    transition: transform 0.2s ease;
  }
  .consent-toggle input:checked + .consent-toggle-slider {
    background: #2563eb;
  }
  .consent-toggle input:checked + .consent-toggle-slider::before {
    transform: translateX(18px);
  }
  .consent-toggle input:focus-visible + .consent-toggle-slider {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .consent-modal-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid #e5e7eb;
  }
  .consent-modal-actions .consent-btn {
    color: #111827;
    border-color: #d1d5db;
  }
  .consent-modal-actions .consent-btn--primary {
    background: #2563eb;
    color: white;
    border-color: #2563eb;
  }
  .consent-modal-actions .consent-btn--primary:hover {
    background: #1d4ed8;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .consent-banner { transition: none; }
    .consent-toggle-slider,
    .consent-toggle-slider::before { transition: none; }
  }
</style>

<script is:inline>
  (function() {
    var STORAGE_KEY = 'consent_v2';
    var COOKIE_NAME = 'consent_v2';
    var COOKIE_DAYS = 390; // 13 mois max CNIL
    var DELAY_MS = 1500;

    function readChoice() {
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (raw) return JSON.parse(raw);
      } catch (e) {}
      var match = document.cookie.match(new RegExp('(^|; )' + COOKIE_NAME + '=([^;]+)'));
      if (match) {
        try { return JSON.parse(decodeURIComponent(match[2])); } catch (e) {}
      }
      return null;
    }

    function saveChoice(choice) {
      var record = { ads: !!choice.ads, ts: Date.now() };
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(record)); } catch (e) {}
      var expires = new Date(Date.now() + COOKIE_DAYS * 864e5).toUTCString();
      document.cookie = COOKIE_NAME + '=' + encodeURIComponent(JSON.stringify(record)) +
        '; expires=' + expires + '; path=/; samesite=lax; secure';
      applyConsent(record);
    }

    function applyConsent(record) {
      if (typeof window.gtag !== 'function') {
        window.dataLayer = window.dataLayer || [];
        window.gtag = function() { window.dataLayer.push(arguments); };
      }
      var grant = record && record.ads ? 'granted' : 'denied';
      window.gtag('consent', 'update', {
        ad_storage: grant,
        ad_user_data: grant,
        ad_personalization: grant,
        analytics_storage: 'granted',
      });
    }

    function showBanner() {
      var banner = document.getElementById('consent-banner');
      if (!banner) return;
      banner.hidden = false;
      requestAnimationFrame(function() {
        banner.setAttribute('data-visible', '');
      });
    }

    function hideBanner() {
      var banner = document.getElementById('consent-banner');
      if (!banner) return;
      banner.removeAttribute('data-visible');
      setTimeout(function() { banner.hidden = true; }, 350);
    }

    function openModal() {
      var modal = document.getElementById('consent-modal');
      if (!modal) return;
      var existing = readChoice();
      var toggle = document.getElementById('consent-ads-toggle');
      if (toggle) toggle.checked = !!(existing && existing.ads);
      modal.hidden = false;
      hideBanner();
    }

    function closeModal() {
      var modal = document.getElementById('consent-modal');
      if (!modal) return;
      modal.hidden = true;
    }

    function handleAction(action) {
      if (action === 'accept') {
        saveChoice({ ads: true });
        hideBanner();
      } else if (action === 'refuse') {
        saveChoice({ ads: false });
        hideBanner();
      } else if (action === 'customize') {
        openModal();
      } else if (action === 'save-custom') {
        var toggle = document.getElementById('consent-ads-toggle');
        saveChoice({ ads: !!(toggle && toggle.checked) });
        closeModal();
        hideBanner();
      }
    }

    function init() {
      var existing = readChoice();
      if (existing) {
        applyConsent(existing);
        return;
      }
      setTimeout(showBanner, DELAY_MS);
    }

    document.addEventListener('click', function(e) {
      var target = e.target;
      if (!target) return;
      var action = target.getAttribute && target.getAttribute('data-consent-action');
      if (action) { handleAction(action); return; }
      if (target.hasAttribute && target.hasAttribute('data-consent-close')) { closeModal(); }
    });

    // Expose pour "Gerer mes cookies" du footer
    window.openConsentSettings = openModal;

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
