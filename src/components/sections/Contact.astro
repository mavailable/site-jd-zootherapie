---
import { getSiteInfo, getContact } from '@data/content';

const siteInfo = await getSiteInfo();
const contact = await getContact();
---

<section id="contact" class="bg-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <h2 class="font-heading font-semibold text-2xl md:text-[2rem] text-primary-900 mb-3">
        {contact.title}
      </h2>
      <p class="text-neutral-600 leading-relaxed max-w-xl mx-auto text-sm">
        {contact.subtitle}
      </p>
    </div>

    <!-- 3 cartes de contact -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-12 max-w-4xl mx-auto">

      <!-- Carte 1 : Réserver un appel (cal.eu) — mise en avant -->
      <a
        href="https://cal.eu/jdzootherapie/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="group bg-accent-50 border-2 border-accent-200 rounded-xl p-6 text-center hover:border-accent-400 hover:shadow-md transition-all"
      >
        <div class="inline-flex items-center justify-center w-12 h-12 bg-accent-100 text-accent-700 rounded-xl mb-4 group-hover:bg-accent-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-primary-900 mb-1">Réserver un appel</h3>
        <p class="text-xs text-neutral-500 mb-3">Choisissez un créneau de 30 min — Jennifer vous rappelle.</p>
        <span class="inline-flex items-center gap-1 text-accent-700 font-semibold text-sm group-hover:gap-2 transition-all">
          Prendre RDV
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </a>

      <!-- Carte 2 : Appeler -->
      <a
        href={`tel:${siteInfo.phone}`}
        class="group bg-white border-2 border-primary-200 rounded-xl p-6 text-center hover:border-primary-400 hover:shadow-md transition-all"
      >
        <div class="inline-flex items-center justify-center w-12 h-12 bg-primary-100 text-primary-600 rounded-xl mb-4 group-hover:bg-primary-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        </div>
        <h3 class="font-heading font-semibold text-primary-900 mb-1">Appeler Jennifer</h3>
        <p class="text-xs text-neutral-500 mb-3">Réponse immédiate aux heures ouvrables.</p>
        <span class="inline-flex items-center gap-1 text-primary-600 font-semibold text-sm">
          {siteInfo.phoneDisplay}
        </span>
      </a>

      <!-- Carte 3 : Formulaire (scroll vers le bas) -->
      <button
        type="button"
        onclick="document.getElementById('contact-form-section').scrollIntoView({behavior:'smooth'})"
        class="group bg-white border-2 border-neutral-200 rounded-xl p-6 text-center hover:border-primary-300 hover:shadow-md transition-all cursor-pointer text-left"
      >
        <div class="inline-flex items-center justify-center w-12 h-12 bg-neutral-100 text-neutral-600 rounded-xl mb-4 group-hover:bg-primary-100 group-hover:text-primary-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <h3 class="font-heading font-semibold text-primary-900 mb-1">Envoyer un message</h3>
        <p class="text-xs text-neutral-500 mb-3">Pour les demandes détaillées ou les structures.</p>
        <span class="inline-flex items-center gap-1 text-primary-600 font-semibold text-sm group-hover:gap-2 transition-all">
          Écrire
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
        </span>
      </button>
    </div>

    <!-- Infos complémentaires -->
    <div class="flex flex-wrap justify-center gap-6 mb-12 text-sm text-neutral-600">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
        <span>{siteInfo.address.postalCode} {siteInfo.address.city} — Metz, Thionville et toute la Moselle</span>
      </div>
      <a href={`mailto:${siteInfo.email}`} class="flex items-center gap-2 hover:text-primary-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span>{siteInfo.email}</span>
      </a>
      <a
        href="/plaquette-jd-zootherapie.pdf"
        download="Plaquette-JD-Zootherapie.pdf"
        class="flex items-center gap-2 hover:text-primary-600 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span>Plaquette PDF</span>
      </a>
    </div>

    <!-- Formulaire -->
    <div id="contact-form-section" class="max-w-2xl mx-auto">
      <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-6 md:p-8">
        <h3 class="font-heading font-semibold text-lg text-primary-900 mb-5">Envoyer un message</h3>

          <div aria-live="polite" aria-atomic="true" class="sr-only" id="form-status"></div>
          <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5">
            <input type="hidden" name="access_key" value="9b6f8df0-5af1-4802-92f1-1ec224519398" />
            <input type="hidden" name="from_name" value="JD Zoothérapie — Site web" />
            <input type="hidden" name="subject" value="Nouveau message depuis jdzootherapeute.fr" />
            <input type="hidden" name="redirect" value="https://jdzootherapeute.fr/merci" />
            <!-- Reply-to : utilise le champ email si rempli -->
            <input type="hidden" name="replyto" value="" id="replyto-field" />
            <!-- Honeypot anti-spam -->
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" aria-hidden="true" />

            <div>
              <label for="contact-name" class="block text-sm font-medium text-neutral-800 mb-1.5">
                Votre prénom et nom <span class="text-accent-700" aria-hidden="true">*</span>
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                autocomplete="name"
                class="w-full px-4 py-3 border border-neutral-300 rounded bg-white text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm min-h-[44px] transition-shadow"
                placeholder="Marie Dupont"
              />
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              <div>
                <label for="contact-phone" class="block text-sm font-medium text-neutral-800 mb-1.5">Téléphone</label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  autocomplete="tel"
                  class="w-full px-4 py-3 border border-neutral-300 rounded bg-white text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm min-h-[44px] transition-shadow"
                  placeholder="06 00 00 00 00"
                />
              </div>
              <div>
                <label for="contact-email" class="block text-sm font-medium text-neutral-800 mb-1.5">Email</label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  autocomplete="email"
                  class="w-full px-4 py-3 border border-neutral-300 rounded bg-white text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm min-h-[44px] transition-shadow"
                  placeholder="votre@email.fr"
                />
              </div>
            </div>

            <div>
              <label for="contact-message" class="block text-sm font-medium text-neutral-800 mb-1.5">
                Votre message <span class="text-accent-700" aria-hidden="true">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="4"
                class="w-full px-4 py-3 border border-neutral-300 rounded bg-white text-neutral-800 placeholder-neutral-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm resize-y transition-shadow"
                placeholder="Décrivez votre situation en quelques mots..."
              ></textarea>
            </div>

            <div class="flex items-start gap-2">
              <input type="checkbox" id="contact-consent" name="consent" required
                class="mt-1 w-4 h-4 rounded border-neutral-300 text-primary-600 focus:ring-primary-500" />
              <label for="contact-consent" class="text-neutral-500 text-xs leading-relaxed">
                J'accepte que mes données soient utilisées pour répondre à ma demande.
                <a href="/politique-confidentialite" class="underline hover:text-primary-600 transition-colors">Politique de confidentialité</a>.
              </label>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center gap-4">
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-2 bg-accent-700 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-accent-800 transition-colors min-h-[44px] w-full sm:w-auto"
              >
                {contact.buttonText}
              </button>
            </div>
          </form>

          <script>
            const emailInput = document.getElementById('contact-email') as HTMLInputElement | null;
            const replytoField = document.getElementById('replyto-field') as HTMLInputElement | null;
            if (emailInput && replytoField) {
              emailInput.addEventListener('input', () => { replytoField.value = emailInput.value; });
            }
          </script>
        </div>
      </div>
    </div>
  </div>
</section>
