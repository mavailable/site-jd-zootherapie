---
import { getHero } from '@data/content';

const hero = await getHero();
---

<section class="relative bg-primary-950 overflow-hidden min-h-[500px] flex items-center">
  <!-- Background: photo séance Jennifer -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src="/images/hero-bg.webp"
      srcset="/images/hero-bg-mobile.webp 768w, /images/hero-bg.webp 1920w"
      sizes="(max-width: 767px) 100vw, 100vw"
      alt=""
      class="w-full h-full object-cover object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1920"
      height="864"
    />
    <!-- Overlay sombre pour lisibilité du texte -->
    <div class="absolute inset-0 bg-gradient-to-r from-primary-950/90 via-primary-950/70 to-primary-950/30"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 lg:py-32 w-full">
    <div class="max-w-2xl">
      <!-- Badge certification -->
      <div class="inline-flex items-center gap-2 bg-primary-700/60 border border-primary-600/50 text-primary-200 text-xs font-medium px-3 py-1.5 rounded-full mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-accent-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        Praticienne certifiée IFZ — Membre du Syndicat Français des Zoothérapeutes
      </div>

      <h1 class="font-heading font-bold text-3xl md:text-5xl leading-tight text-white mb-5"
          data-cms-field="hero.h1" data-cms-type="text">
        {hero.h1}
      </h1>
      <p class="text-primary-100 text-lg md:text-xl leading-relaxed mb-8"
         data-cms-field="hero.subtitle" data-cms-type="text">
        {hero.subtitle}
      </p>

      <div class="hidden sm:flex flex-col sm:flex-row gap-4 mb-5">
        <a
          href={hero.ctaPrimaryHref}
          target={hero.ctaPrimaryHref.startsWith('http') ? '_blank' : undefined}
          rel={hero.ctaPrimaryHref.startsWith('http') ? 'noopener noreferrer' : undefined}
          data-track="cta"
          class="inline-flex items-center justify-center gap-2 bg-accent-700 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-accent-800 transition-colors min-h-[44px]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          <span data-cms-field="hero.ctaPrimaryText" data-cms-type="text">{hero.ctaPrimaryText}</span>
        </a>
        <a
          href={hero.ctaSecondaryHref}
          class="inline-flex items-center justify-center border-2 border-white/70 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-white/10 transition-colors min-h-[44px]"
        >
          <span data-cms-field="hero.ctaSecondaryText" data-cms-type="text">{hero.ctaSecondaryText}</span>
        </a>
      </div>

      <p class="hidden sm:flex text-primary-300 text-sm items-center gap-1.5">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-accent-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        <span data-cms-field="hero.reassurance" data-cms-type="text">{hero.reassurance}</span>
      </p>
    </div>
  </div>
</section>
