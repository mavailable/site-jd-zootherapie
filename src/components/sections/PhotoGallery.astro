---
// Galerie photo — moments réels de séances JD Zoothérapie
const photos = [
  {
    src: '/images/session-senior.webp',
    alt: 'Séance de médiation animale avec un monsieur âgé et Uxo, le Berger américain miniature médiateur',
    caption: 'Stimulation cognitive avec Tips',
    cols: 'col-span-1',
  },
  {
    src: '/images/hero-bg.webp',
    alt: 'Mains d\'une personne âgée caressant Uxo, le Berger américain miniature médiateur, lors d\'une séance à domicile',
    caption: 'La connexion au cœur de chaque séance',
    cols: 'col-span-2',
  },
  {
    src: '/images/session-enfant.webp',
    alt: 'Enfant accompagnant le chien médiateur en laisse lors d\'une promenade thérapeutique',
    caption: 'Promenade thérapeutique avec un enfant',
    cols: 'col-span-1',
  },
  {
    src: '/images/session-cuddle.webp',
    alt: 'Uxo, le Berger américain miniature médiateur, blotti contre un patient en séance de bien-être',
    caption: 'Apaisement et bien-être',
    cols: 'col-span-2',
  },
  {
    src: '/images/session-jeune-lapin.webp',
    alt: 'Jeune adulte en interaction apaisante avec Tap-Tap le lapin bélier médiateur',
    caption: 'Tap-Tap accompagne les jeunes adultes',
    cols: 'col-span-1',
  },
];
---

<section class="bg-neutral-50 py-14 md:py-18 overflow-hidden" aria-label="Galerie de séances">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <p class="text-accent-700 font-semibold text-sm uppercase tracking-wider mb-2">En images</p>
      <h2 class="font-heading font-bold text-2xl md:text-3xl text-primary-900">
        Des moments vrais, au cœur des séances
      </h2>
      <p class="text-neutral-600 mt-3 max-w-xl mx-auto">
        Chaque séance est unique. Ces photos témoignent de la qualité de présence et de la douceur des animaux médiateurs.
      </p>
    </div>

    <!-- Grille masonry simulée -->
    <div class="grid grid-cols-3 gap-3 md:gap-4">

      <!-- Ligne 1 : portrait étroit + paysage large -->
      <div class="col-span-1 rounded-xl overflow-hidden aspect-[3/4] shadow-sm">
        <img
          src="/images/session-senior.webp"
          alt="Séance de médiation animale avec un monsieur âgé et Uxo, le Berger américain miniature médiateur"
          class="w-full h-full object-cover object-top transition-transform duration-500"
          loading="lazy"
          decoding="async"
          width="300"
          height="400"
        />
      </div>
      <div class="col-span-2 rounded-xl overflow-hidden aspect-[16/9] shadow-sm">
        <img
          src="/images/hero-bg.webp"
          alt="Mains d'une personne âgée caressant Uxo, le Berger américain miniature médiateur, lors d'une séance à domicile"
          class="w-full h-full object-cover object-center transition-transform duration-500"
          loading="lazy"
          decoding="async"
          width="1920"
          height="864"
        />
      </div>

      <!-- Ligne 2 : large + portrait -->
      <div class="col-span-2 rounded-xl overflow-hidden aspect-[16/9] shadow-sm">
        <img
          src="/images/session-cuddle.webp"
          alt="Uxo, le Berger américain miniature médiateur, blotti contre un patient en séance de bien-être"
          class="w-full h-full object-cover object-center transition-transform duration-500"
          loading="lazy"
          decoding="async"
          width="800"
          height="414"
        />
      </div>
      <div class="col-span-1 rounded-xl overflow-hidden aspect-[3/4] shadow-sm">
        <img
          src="/images/session-enfant.webp"
          alt="Enfant accompagnant le chien médiateur lors d'une promenade thérapeutique"
          class="w-full h-full object-cover object-top transition-transform duration-500"
          loading="lazy"
          decoding="async"
          width="300"
          height="400"
        />
      </div>

    </div>

    <!-- Citation d'ancrage -->
    <blockquote class="mt-10 text-center">
      <p class="text-primary-800 italic text-lg md:text-xl font-heading leading-relaxed max-w-2xl mx-auto">
        « L'animal ne juge pas. Il offre une présence pure, qui permet à chacun de s'ouvrir à son propre rythme. »
      </p>
      <footer class="mt-3 text-neutral-500 text-sm">— Jennifer De Groeve, zoothérapeute</footer>
    </blockquote>

  </div>
</section>
