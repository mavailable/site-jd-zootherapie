---
import { getGallery } from '@data/content';

const gallery = await getGallery();

// Layout config derived from cols (layout concern, not CMS content)
const layoutMap: Record<number, { colClass: string; aspect: string; objectPos: string; width: number; height: number }> = {
  1: { colClass: 'col-span-1', aspect: 'aspect-[3/4]', objectPos: 'object-top', width: 300, height: 400 },
  2: { colClass: 'col-span-2', aspect: 'aspect-[16/9]', objectPos: 'object-center', width: 800, height: 414 },
};
---

<section class="bg-neutral-50 py-14 md:py-18 overflow-hidden" aria-label="Galerie de séances">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-10">
      <p class="text-accent-700 font-semibold text-sm uppercase tracking-wider mb-2" data-cms-field="gallery.sectionLabel" data-cms-type="text">{gallery.sectionLabel}</p>
      <h2 class="font-heading font-bold text-2xl md:text-3xl text-primary-900" data-cms-field="gallery.heading" data-cms-type="text">
        {gallery.heading}
      </h2>
      <p class="text-neutral-600 mt-3 max-w-xl mx-auto" data-cms-field="gallery.description" data-cms-type="text">
        {gallery.description}
      </p>
    </div>

    <!-- Grille masonry simulée -->
    <div class="grid grid-cols-3 gap-3 md:gap-4">
      {gallery.photos.map((photo: any, i: number) => {
        const layout = layoutMap[photo.cols] || layoutMap[1];
        return (
          <div class={`${layout.colClass} rounded-xl overflow-hidden ${layout.aspect} shadow-sm`}>
            <img
              src={photo.src}
              alt={photo.alt}
              data-cms-field={`gallery.photos[${i}]`}
              data-cms-type="image"
              class={`w-full h-full object-cover ${layout.objectPos} transition-transform duration-500`}
              loading="lazy"
              decoding="async"
              width={layout.width}
              height={layout.height}
            />
          </div>
        );
      })}
    </div>

    <!-- Citation d'ancrage -->
    <blockquote class="mt-10 text-center">
      <p class="text-primary-800 italic text-lg md:text-xl font-heading leading-relaxed max-w-2xl mx-auto" data-cms-field="gallery.quote" data-cms-type="text">
        &laquo; {gallery.quote} &raquo;
      </p>
      <footer class="mt-3 text-neutral-500 text-sm" data-cms-field="gallery.quoteAttribution" data-cms-type="text">&mdash; {gallery.quoteAttribution}</footer>
    </blockquote>

  </div>
</section>
