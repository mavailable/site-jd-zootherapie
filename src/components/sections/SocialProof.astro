---
import { getTestimonials } from '@data/content';

const testimonials = getTestimonials();

const stats = [
  {
    value: '+20 ans',
    label: 'dans le soin et l\'accompagnement',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    value: '3 animaux',
    label: 'médiateurs formés et encadrés',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>`,
  },
  {
    value: 'Tous âges',
    label: 'de 3 à 99 ans, avec ou sans handicap',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    value: '15 km',
    label: 'rayon d\'intervention autour de Verny',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="text-center mb-12">
      <h2 class="font-heading font-semibold text-2xl md:text-[2rem] text-primary-900 mb-3">
        Ce que la médiation animale change au quotidien
      </h2>
      <p class="text-neutral-600 max-w-xl mx-auto text-base">
        Des séances construites dans la douceur et la confiance, avec des animaux médiateurs formés.
      </p>
    </div>

    <!-- Stats band — fond primary-50 -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-16">
      {stats.map((stat) => (
        <div class="text-center p-5 bg-primary-50 rounded-xl border border-primary-100">
          <div class="inline-flex items-center justify-center w-11 h-11 bg-primary-100 text-primary-600 rounded-lg mb-3" set:html={stat.icon} />
          <p class="font-heading font-bold text-2xl md:text-3xl text-primary-800 leading-tight mb-1">{stat.value}</p>
          <p class="text-neutral-600 text-xs leading-snug">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Badge Google — note globale -->
    <div class="flex justify-center mb-8">
      <a
        href="https://www.google.com/maps/place/De+Groeve+Jennifer+zootherapie+-+m%C3%A8diation+animale/@49.0208014,6.7659488,17z/data=!4m8!3m7!1s0x4794e99a7ea728f9:0x6eab055d3a0c838!8m2!3d49.0208014!4d6.7659488!9m1!1b1!16s%2Fg%2F11xng642pt"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-white border border-neutral-200 rounded-xl px-5 py-3 shadow-sm hover:shadow-md transition-shadow"
        aria-label="Voir nos avis Google"
      >
        <!-- Logo Google -->
        <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <!-- Étoiles -->
        <div class="flex items-center gap-1">
          {[1,2,3,4,5].map(() => (
            <svg class="w-4 h-4 text-yellow-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
        </div>
        <div>
          <span class="font-bold text-neutral-900 text-sm">5,0</span>
          <span class="text-neutral-500 text-xs ml-1">· 9 avis Google</span>
        </div>
      </a>
    </div>

    <!-- Testimonials grid — fond secondary-50 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <article class="bg-secondary-50 border border-secondary-200 rounded-xl p-6 flex flex-col">
          <svg class="w-8 h-8 text-secondary-400 mb-3 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <blockquote class="text-neutral-700 text-sm leading-relaxed mb-4 flex-1 italic">
            {t.quote}
          </blockquote>
          <footer class="border-t border-secondary-200 pt-3 mt-auto">
            <p class="font-semibold text-primary-900 text-sm">{t.author}</p>
            <p class="text-neutral-500 text-xs">{t.context}</p>
          </footer>
        </article>
      ))}
    </div>

    <!-- Lien vers tous les avis Google -->
    <div class="text-center mt-8">
      <a
        href="https://www.google.com/maps/place/De+Groeve+Jennifer+zootherapie+-+m%C3%A8diation+animale/@49.0208014,6.7659488,17z/data=!4m8!3m7!1s0x4794e99a7ea728f9:0x6eab055d3a0c838!8m2!3d49.0208014!4d6.7659488!9m1!1b1!16s%2Fg%2F11xng642pt"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-primary-600 hover:text-primary-800 text-sm font-medium transition-colors"
      >
        Voir tous les avis sur Google
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

  </div>
</section>
