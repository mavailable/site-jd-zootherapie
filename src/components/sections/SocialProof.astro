---
const stats = [
  { value: '+20 ans', label: 'dans le soin et l\'accompagnement' },
  { value: '3 animaux', label: 'médiateurs formés et encadrés' },
  { value: 'Tous publics', label: 'de 3 à 99 ans, avec ou sans handicap' },
];

const testimonials = [
  {
    quote: 'Depuis que Jennifer intervient auprès de mon père atteint d\'Alzheimer, il est plus apaisé et sourit à nouveau. Les séances avec Tips sont le moment fort de sa semaine.',
    author: 'Marie-Claire D.',
    context: 'Famille d\'un résident en EHPAD',
  },
  {
    quote: 'Mon fils avait du mal à gérer ses émotions. Grâce aux ateliers avec les animaux, il a gagné en confiance et en sérénité. Il réclame chaque séance !',
    author: 'Sophie R.',
    context: 'Maman d\'un enfant de 7 ans',
  },
  {
    quote: 'Jennifer sait adapter ses interventions à chaque résident. Les animaux créent un lien immédiat, et les progrès sont visibles dès les premières séances.',
    author: 'Équipe éducative',
    context: 'IME de Moselle',
  },
];
---

<section class="bg-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section title -->
    <h2 class="font-heading font-semibold text-2xl md:text-[2rem] text-primary-900 text-center mb-12">
      Ce que la médiation animale apporte au quotidien
    </h2>

    <!-- Stats band -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
      {stats.map((stat) => (
        <div class="text-center p-6 bg-primary-50 rounded-lg">
          <p class="font-heading font-bold text-2xl md:text-3xl text-primary-800 mb-1">{stat.value}</p>
          <p class="text-neutral-600 text-sm">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <article class="bg-secondary-50 border border-secondary-200 rounded-lg p-6 flex flex-col">
          <!-- Decorative quote -->
          <svg class="w-8 h-8 text-secondary-400 mb-3 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
          </svg>
          <blockquote class="text-neutral-700 text-sm leading-relaxed mb-4 flex-1">
            {t.quote}
          </blockquote>
          <footer class="border-t border-secondary-200 pt-3 mt-auto">
            <p class="font-semibold text-primary-900 text-sm">{t.author}</p>
            <p class="text-neutral-500 text-xs">{t.context}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
