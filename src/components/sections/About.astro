---
import { getAbout } from '@data/content';

interface Props {
  /** Mode snippet pour la homepage (texte court) */
  snippet?: boolean;
}

const { snippet = false } = Astro.props;
const about = await getAbout();

// En mode snippet : 1 paragraphe + lien vers /a-propos
// En mode complet : tous les paragraphes + section animaux
const paragraphsToShow = snippet ? about.paragraphs.slice(0, 1) : about.paragraphs;

const animalPhotos: Record<string, string> = {
  'Tips':    '/images/animal-tips.webp',
  'Uxo':     '/images/animal-uxo.webp',
  'Tap-Tap': '/images/animal-tap-tap.webp',
};
---

<section id="a-propos" class="bg-white py-16 md:py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10 items-center">

      <!-- Photo Jennifer (2/5) -->
      <div class="md:col-span-2 order-1">
        <div class="relative w-full rounded-2xl overflow-hidden shadow-xl">
          <img
            src="/images/jennifer-pro.webp"
            alt="Jennifer De Groeve, zoothérapeute certifiée, avec ses animaux médiateurs — Tips, Uxo et Tap-Tap"
            class="w-full object-cover object-top"
            loading="lazy"
            decoding="async"
            width="800"
            height="1580"
          />
          <!-- Badge flottant -->
          <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-sm rounded-xl px-4 py-3 shadow-sm">
            <p class="text-primary-900 font-semibold text-sm leading-tight">Jennifer De Groeve</p>
            <p class="text-neutral-600 text-xs mt-0.5">Praticienne certifiée IFZ · Zoothérapeute</p>
          </div>
        </div>
      </div>

      <!-- Texte (3/5) -->
      <article class="md:col-span-3 order-2">
        <h2 class="font-heading font-semibold text-2xl md:text-[2rem] text-primary-900 mb-6">
          {about.founderName} — {about.founderTitle}
        </h2>

        <div class="text-neutral-700 leading-relaxed space-y-4">
          {paragraphsToShow.map((p) => (
            <p set:html={p} />
          ))}
        </div>

        <!-- Badges certifications -->
        <div class="flex flex-wrap gap-2.5 mt-6">
          <span class="inline-flex items-center gap-1.5 bg-secondary-100 text-secondary-800 px-3 py-1.5 rounded-full text-xs font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            Certifiée IFZ
          </span>
          <span class="inline-flex items-center gap-1.5 bg-secondary-100 text-secondary-800 px-3 py-1.5 rounded-full text-xs font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            Syndicat Français des Zoothérapeutes
          </span>
          <span class="inline-flex items-center gap-1.5 bg-secondary-100 text-secondary-800 px-3 py-1.5 rounded-full text-xs font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            +20 ans dans le soin
          </span>
        </div>

        {snippet ? (
          <div class="mt-6">
            <a
              href="/a-propos"
              class="inline-flex items-center gap-2 bg-accent-700 text-white px-6 py-3 rounded font-semibold text-sm hover:bg-accent-800 transition-colors min-h-[44px]"
            >
              Découvrir mon parcours
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </div>
        ) : (
          <>
            {/* Section animaux — mode complet seulement */}
            <div class="mt-8 pt-6 border-t border-neutral-100">
              <h3 class="font-heading font-semibold text-lg text-primary-900 mb-4">
                Les animaux médiateurs
              </h3>
              <div class="space-y-3">
                {about.animals.map((animal) => {
                  const photo = animalPhotos[animal.name];
                  return (
                  <div class="flex items-start gap-3 p-3.5 bg-primary-50 rounded-lg border border-primary-100">
                    {photo ? (
                      <img
                        src={photo}
                        alt={`${animal.name}, ${animal.breed} — animal médiateur de Jennifer De Groeve`}
                        class="w-10 h-10 rounded-full object-cover shrink-0 border-2 border-primary-200"
                        loading="lazy"
                        width="40"
                        height="40"
                      />
                    ) : (
                      <div class="w-10 h-10 bg-primary-200 rounded-full flex items-center justify-center shrink-0 text-primary-700 font-heading font-bold text-sm">
                        {animal.name[0]}
                      </div>
                    )}
                    <div>
                      <p class="font-semibold text-primary-900 text-sm">{animal.name} <span class="font-normal text-neutral-500">— {animal.breed}</span></p>
                      <p class="text-neutral-600 text-xs mt-0.5">{animal.role}</p>
                    </div>
                  </div>
                  );
                })}
              </div>
            </div>
          </>
        )}
      </article>
    </div>
  </div>
</section>
