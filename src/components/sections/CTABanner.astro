---
import { getSiteInfo } from '@data/content';

interface Props {
  title?: string;
  text?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaSecondaryText?: string;
  ctaSecondaryHref?: string;
}

const siteInfo = await getSiteInfo();

const {
  title = 'Prêt à découvrir la médiation animale ?',
  text = 'Réservez un appel découverte gratuit et sans engagement. Jennifer vous rappelle au créneau choisi.',
  ctaText = 'Réserver un appel gratuit',
  ctaHref = 'https://cal.eu/jdzootherapie/30min',
  ctaSecondaryText = 'Appeler directement',
  ctaSecondaryHref = `tel:${siteInfo.phone}`,
} = Astro.props;
---

<section class="bg-primary-800 py-14 md:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-semibold text-2xl md:text-3xl text-white mb-4">
      {title}
    </h2>
    {text && (
      <p class="text-primary-100 mb-8 max-w-xl mx-auto leading-relaxed">
        {text}
      </p>
    )}
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={ctaHref}
        target={ctaHref.startsWith('http') ? '_blank' : undefined}
        rel={ctaHref.startsWith('http') ? 'noopener noreferrer' : undefined}
        data-track="cta"
        class="inline-flex items-center justify-center gap-2 bg-accent-400 text-neutral-950 px-7 py-3.5 rounded font-semibold text-base hover:bg-accent-300 transition-colors min-h-[44px]"
      >
        {ctaHref.startsWith('tel:') ? (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        ) : (
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        )}
        {ctaText}
      </a>
      <a
        href={ctaSecondaryHref}
        class="inline-flex items-center justify-center border-2 border-white/70 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-white/10 transition-colors min-h-[44px]"
      >
        {ctaSecondaryText}
      </a>
    </div>
  </div>
</section>
