---
import Button from '@components/ui/Button.astro';
import { business } from '@data/business';
---

<section class="bg-primary-800 py-14 md:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="font-heading font-semibold text-2xl md:text-[2rem] text-white mb-4">
      Offrez un moment de douceur et de bien-être
    </h2>
    <p class="text-primary-100 mb-8 max-w-2xl mx-auto">
      Que ce soit pour vous, un proche ou une structure, Jennifer est à votre écoute pour construire un accompagnement sur mesure.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="#contact" variant="primary" size="lg" class="bg-accent-400 text-neutral-950 hover:bg-accent-300">
        Parlons de votre projet
      </Button>
      <Button href={`tel:${business.phone}`} variant="outline" size="lg" class="border-white/80 text-white hover:bg-white/10 hover:text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        {business.phoneDisplay}
      </Button>
    </div>
  </div>
</section>
