---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();
---

<BaseLayout
  title="Message envoyé — JD Zoothérapie"
  description="Votre message a bien été envoyé. Jennifer De Groeve vous recontactera dans les 48 heures."
  noindex={true}
>
  <Header slot="header" />

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">

      <!-- Icône succès -->
      <div class="inline-flex items-center justify-center w-20 h-20 bg-primary-100 text-primary-600 rounded-full mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>

      <h1 class="font-heading font-bold text-3xl md:text-4xl text-primary-900 mb-4">
        Merci pour votre message !
      </h1>
      <p class="text-neutral-600 text-lg leading-relaxed mb-3">
        Votre demande a bien été envoyée à Jennifer.
      </p>
      <p class="text-neutral-500 leading-relaxed mb-10">
        Elle vous recontactera <strong class="text-neutral-700">dans les 48 heures</strong> pour comprendre votre situation et vous proposer un accompagnement adapté.
      </p>

      <!-- Rappel numéro -->
      <div class="bg-primary-50 border border-primary-100 rounded-xl p-5 mb-10 text-left max-w-sm mx-auto">
        <p class="text-sm font-medium text-primary-800 mb-1">Besoin d'une réponse rapide ?</p>
        <p class="text-sm text-primary-700 mb-3">Appelez Jennifer directement :</p>
        <a
          href={`tel:${siteInfo.phone}`}
          class="inline-flex items-center gap-2 bg-accent-700 text-white px-5 py-3 rounded font-semibold text-base hover:bg-accent-800 transition-colors min-h-[44px] w-full justify-center"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          {siteInfo.phoneDisplay}
        </a>
      </div>

      <!-- CTAs secondaires -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center mb-10">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 bg-primary-800 text-white px-6 py-3.5 rounded font-semibold text-base hover:bg-primary-900 transition-colors min-h-[44px]"
        >
          Retour à l'accueil
        </a>
        <a
          href="/zootherapie"
          class="inline-flex items-center justify-center gap-2 border border-primary-200 text-primary-800 bg-white px-6 py-3.5 rounded font-medium text-base hover:border-primary-400 hover:bg-primary-50 transition-colors min-h-[44px]"
        >
          En savoir plus sur la zoothérapie
        </a>
      </div>

      <!-- Réseaux sociaux -->
      {(siteInfo.social.facebook || siteInfo.social.instagram) && (
        <div class="pt-8 border-t border-neutral-100">
          <p class="text-sm text-neutral-500 mb-4">Suivez les actualités de Jennifer :</p>
          <div class="flex gap-3 justify-center">
            {siteInfo.social.facebook && (
              <a
                href={siteInfo.social.facebook}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-[#1877F2] text-white px-5 py-2.5 rounded font-medium text-sm hover:opacity-90 transition-opacity min-h-[40px]"
                aria-label="Page Facebook de JD Zoothérapie"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                Facebook
              </a>
            )}
            {siteInfo.social.instagram && (
              <a
                href={siteInfo.social.instagram}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white px-5 py-2.5 rounded font-medium text-sm hover:opacity-90 transition-opacity min-h-[40px]"
                aria-label="Instagram de JD Zoothérapie"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                Instagram
              </a>
            )}
          </div>
        </div>
      )}

    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
