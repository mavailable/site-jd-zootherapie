---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { getSiteInfo } from '@data/content';

const siteInfo = getSiteInfo();
---

<BaseLayout
  title="Page introuvable (404) — JD Zoothérapie"
  description="La page que vous cherchez n'existe pas ou a été déplacée."
  noindex={true}
>
  <Header slot="header" />

  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 text-center">

      <!-- 404 -->
      <p class="text-7xl md:text-9xl font-heading font-bold text-primary-100 leading-none mb-2">404</p>

      <!-- Icône animaux -->
      <div class="text-4xl mb-6" aria-hidden="true">🐕</div>

      <h1 class="font-heading font-bold text-2xl md:text-3xl text-primary-900 mb-4">
        Cette page s'est éclipsée...
      </h1>
      <p class="text-neutral-600 leading-relaxed mb-3">
        La page que vous cherchez a peut-être été déplacée, renommée ou n'existe plus.
      </p>
      <p class="text-neutral-500 text-sm mb-10">
        Tips, Uxo et Tap-Tap vous invitent à explorer les autres pages du site !
      </p>

      <!-- CTA principal -->
      <a
        href="/"
        class="inline-flex items-center justify-center gap-2 bg-accent-700 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-accent-800 transition-colors min-h-[44px] mb-10"
      >
        Retour à l'accueil
      </a>

      <!-- Navigation rapide -->
      <div class="border-t border-neutral-100 pt-10">
        <p class="text-sm font-medium text-neutral-500 mb-5">Ou accédez directement à :</p>
        <nav aria-label="Pages principales" class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-w-md mx-auto">
          <a href="/zootherapie" class="flex items-center gap-2 px-4 py-3 bg-primary-50 text-primary-700 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors text-left">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            La zoothérapie
          </a>
          <a href="/ateliers" class="flex items-center gap-2 px-4 py-3 bg-primary-50 text-primary-700 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors text-left">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Les ateliers
          </a>
          <a href="/tarifs" class="flex items-center gap-2 px-4 py-3 bg-primary-50 text-primary-700 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors text-left">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Tarifs
          </a>
          <a href="/a-propos" class="flex items-center gap-2 px-4 py-3 bg-primary-50 text-primary-700 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors text-left">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Mon parcours
          </a>
          <a href="/faq" class="flex items-center gap-2 px-4 py-3 bg-primary-50 text-primary-700 rounded-lg text-sm font-medium hover:bg-primary-100 transition-colors text-left">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            FAQ
          </a>
          <a
            href={`tel:${siteInfo.phone}`}
            class="flex items-center gap-2 px-4 py-3 bg-accent-50 text-accent-700 rounded-lg text-sm font-semibold hover:bg-accent-100 transition-colors text-left"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            Appeler
          </a>
        </nav>
      </div>

    </div>
  </section>

  <Footer slot="footer" />

  <script defer src="/js/404-track.js"></script>
</BaseLayout>
