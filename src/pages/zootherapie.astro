---

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
import { getBreadcrumbSchema } from '@data/schemas';
import { getPageZootherapie } from '@data/content';

const page = await getPageZootherapie();

const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Accueil', url: 'https://jdzootherapeute.fr/' },
  { name: 'La zoothérapie', url: '/zootherapie' },
]);

const benefitIcons = [
  { bg: 'bg-accent-100', text: 'text-accent-700', svg: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>' },
  { bg: 'bg-primary-100', text: 'text-primary-600', svg: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>' },
  { bg: 'bg-secondary-100', text: 'text-secondary-700', svg: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>' },
  { bg: 'bg-accent-100', text: 'text-accent-700', svg: '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>' },
  { bg: 'bg-primary-100', text: 'text-primary-600', svg: '<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>' },
];
---

<BaseLayout
  title="La médiation animale — Bienfaits et publics | JD Zoothérapie"
  description="Découvrez les bienfaits de la zoothérapie : réduction du stress, stimulation cognitive, lien social. Une approche douce pour tous les âges, en Moselle."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1={page.heroH1}
    subtitle={page.heroSubtitle}
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">La zoothérapie</li>
      </ol>
    </div>
  </nav>

  <!-- Définition -->
  <section class="bg-white py-14 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 data-cms-field="page-zootherapie.introHeading" data-cms-type="text" class="font-heading font-semibold text-xl md:text-2xl text-primary-900 mb-5">
        {page.introHeading}
      </h2>
      <div class="text-neutral-700 leading-relaxed space-y-4">
        {page.introParagraphs.map((p: string, i: number) => (
          <p data-cms-field={`page-zootherapie.introParagraphs[${i}]`} data-cms-type="text" set:html={p} />
        ))}
      </div>
    </div>
  </section>

  <!-- Bienfaits — fond primary-50 -->
  <section class="bg-primary-50 py-14 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 data-cms-field="page-zootherapie.benefitsHeading" data-cms-type="text" class="font-heading font-semibold text-xl md:text-2xl text-primary-900 mb-2">{page.benefitsHeading}</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">

        {page.benefits.map((b: { title: string; description: string }, i: number) => (
          <article class={`bg-white border border-neutral-200 rounded-xl p-5 shadow-sm${i === 4 ? ' md:col-span-2 lg:col-span-1' : ''}`}>
            <div class={`inline-flex items-center justify-center w-10 h-10 ${benefitIcons[i].bg} ${benefitIcons[i].text} rounded-lg mb-3 shrink-0`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={benefitIcons[i].svg} />
            </div>
            <h3 data-cms-field={`page-zootherapie.benefits[${i}].title`} data-cms-type="text" class="font-heading font-semibold text-base text-primary-900 mb-2">{b.title}</h3>
            <p data-cms-field={`page-zootherapie.benefits[${i}].description`} data-cms-type="text" class="text-neutral-700 text-sm leading-relaxed">{b.description}</p>
          </article>
        ))}

      </div>
    </div>
  </section>

  <!-- Publics — fond blanc -->
  <section class="bg-white py-14 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-start">
        <div>
          <h2 data-cms-field="page-zootherapie.publicsHeading" data-cms-type="text" class="font-heading font-semibold text-xl md:text-2xl text-primary-900 mb-5">{page.publicsHeading}</h2>
          <p data-cms-field="page-zootherapie.publicsIntro" data-cms-type="text" class="text-neutral-700 text-sm leading-relaxed mb-4">{page.publicsIntro}</p>
          <ul class="space-y-2.5">
            {page.publicsList.map((item: string, i: number) => (
              <li data-cms-field={`page-zootherapie.publicsList[${i}]`} data-cms-type="text" class="flex items-start gap-2.5 text-sm text-neutral-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-secondary-50 border border-secondary-200 rounded-2xl p-7">
          <h3 data-cms-field="page-zootherapie.sidebarHeading" data-cms-type="text" class="font-heading font-semibold text-lg text-secondary-900 mb-3">{page.sidebarHeading}</h3>
          <p data-cms-field="page-zootherapie.sidebarText" data-cms-type="text" class="text-neutral-700 text-sm leading-relaxed mb-5">{page.sidebarText}</p>
          <a href="https://cal.eu/jdzootherapie/30min" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 bg-accent-700 text-white px-6 py-3 rounded font-semibold text-sm hover:bg-accent-800 transition-colors min-h-[44px] w-full">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span data-cms-field="page-zootherapie.sidebarCta" data-cms-type="text">{page.sidebarCta}</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title={page.ctaTitle}
    text={page.ctaText}
    ctaSecondaryText={page.ctaSecondaryText}
    ctaSecondaryHref="/ateliers"
    cmsPrefix="page-zootherapie"
  />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
