---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import FAQ from '@components/sections/FAQ.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
import { getFaq } from '@data/content';

const faqs = getFaq();
---

<BaseLayout
  title="FAQ — Questions sur la zoothérapie | JD Zoothérapie"
  description="Toutes vos questions sur la zoothérapie : définition, tarifs, zone d'intervention, animaux médiateurs, publics concernés. Jennifer De Groeve répond."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": { "@type": "Answer", "text": f.answer }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://jd-zootherapie.fr/" },
        { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://jd-zootherapie.fr/faq" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1="Questions fréquentes sur la médiation animale et les séances de Jennifer De Groeve"
    variant="light"
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">FAQ</li>
      </ol>
    </div>
  </nav>

  <!-- Toutes les questions — FAQ component sans limite -->
  <FAQ title="Questions fréquentes" />

  <!-- CTA bas de page -->
  <section class="bg-white py-10 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-semibold text-lg text-primary-900 mb-2">Une autre question ?</h2>
      <p class="text-neutral-600 text-sm mb-5">Jennifer répond personnellement — premier échange gratuit, sans engagement.</p>
      <a
        href="tel:+33754812122"
        class="inline-flex items-center justify-center gap-2 bg-accent-700 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-accent-800 transition-colors min-h-[44px]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Appeler le 07 54 81 21 22
      </a>
    </div>
  </section>

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
