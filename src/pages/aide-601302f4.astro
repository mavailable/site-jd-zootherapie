  <script is:inline>
    // --- Auth ---
    const HASH = 'b141e8d004f7e3f30db42b95dbcadd13aefcbcb7a1a763a52e6a800a45263cf7';

    async function sha256(str) {
      const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
    }

    async function tryAuth(password) {
      const hash = await sha256(password);
      if (hash === HASH) {
        sessionStorage.setItem('aide-auth', '1');
        document.getElementById('auth-gate').remove();
        document.getElementById('auth-content').classList.remove('hidden');
        return true;
      }
      return false;
    }

    if (sessionStorage.getItem('aide-auth') === '1') {
      document.getElementById('auth-gate').remove();
      document.getElementById('auth-content').classList.remove('hidden');
    }

    document.getElementById('auth-btn').addEventListener('click', async () => {
      const ok = await tryAuth(document.getElementById('auth-input').value);
      if (!ok) document.getElementById('auth-error').classList.remove('hidden');
    });

    document.getElementById('auth-input').addEventListener('keydown', async (e) => {
      if (e.key === 'Enter') {
        const ok = await tryAuth(e.target.value);
        if (!ok) document.getElementById('auth-error').classList.remove('hidden');
      }
    });

    // --- Tabs ---
    const panels = document.getElementById('panels');
    const tabs = document.querySelectorAll('.tab-btn');
    const sections = panels.querySelectorAll('.tab-panel');
    function activateTab(index) {
      tabs.forEach((b, i) => {
        if (i === index) {
          b.classList.remove('text-neutral-500');
          b.classList.add('text-primary-700', 'bg-primary-50');
        } else {
          b.classList.remove('text-primary-700', 'bg-primary-50');
          b.classList.add('text-neutral-500');
        }
      });
    }
    tabs.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
        activateTab(i);
      });
    });
    let scrollTimeout;
    panels.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const index = Math.round(panels.scrollLeft / panels.offsetWidth);
        activateTab(index);
      }, 50);
    }, { passive: true });

    // --- Publier ---
    const publishBtn = document.getElementById('publish-btn');
    const publishLabel = document.getElementById('publish-label');
    const publishSpinner = document.getElementById('publish-spinner');
    const publishStatus = document.getElementById('publish-status');

    publishBtn.addEventListener('click', async () => {
      if (!confirm('Publier les modifications sur jdzootherapeute.fr ?')) return;
      publishBtn.disabled = true;
      publishLabel.textContent = 'Publication en cours…';
      publishSpinner.classList.remove('hidden');
      publishStatus.className = 'hidden text-sm mt-3 font-medium';

      try {
        const res = await fetch('/api/publish', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
          publishStatus.textContent = 'Modifications publiees — le site sera mis a jour dans 2-3 minutes.';
          publishStatus.className = 'text-sm mt-3 font-medium text-green-700';
          publishLabel.textContent = 'Publie !';
        } else {
          throw new Error(data.error || 'Erreur inconnue');
        }
      } catch (err) {
        publishStatus.textContent = 'Erreur : ' + err.message + ' — contactez marc@muller.im';
        publishStatus.className = 'text-sm mt-3 font-medium text-red-600';
        publishBtn.disabled = false;
        publishLabel.textContent = 'Publier sur jdzootherapeute.fr';
      } finally {
        publishSpinner.classList.add('hidden');
      }
    });
  </script>
