---
export const prerender = false;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Aide — Votre espace administration"
  description="Guide pour modifier le contenu de votre site et consulter vos statistiques."
  noindex={true}
>
  <Header slot="header" />

  <!-- ─── Password Gate ─── -->
  <div id="gate" class="min-h-[60vh] flex items-center justify-center py-16">
    <div class="max-w-sm w-full mx-auto px-4">
      <div class="bg-white border border-neutral-200 rounded-2xl p-8 shadow-sm text-center">
        <div class="flex items-center justify-center w-12 h-12 bg-primary-100 text-primary-600 rounded-xl mx-auto mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        </div>
        <h1 class="font-heading text-xl font-bold text-neutral-900 mb-2">Espace administration</h1>
        <p class="text-sm text-neutral-500 mb-6">Entrez votre mot de passe pour acceder a votre espace.</p>
        <form id="gate-form" class="space-y-4">
          <input type="password" id="pwd" placeholder="Mot de passe" autocomplete="current-password" class="w-full border border-neutral-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" />
          <button type="submit" class="w-full bg-primary-600 text-white font-medium py-3 rounded-xl hover:bg-primary-700 transition-colors text-sm">Acceder</button>
          <p id="gate-error" class="text-red-500 text-xs hidden">Mot de passe incorrect.</p>
        </form>
      </div>
    </div>
  </div>

  <!-- ─── Admin Panel (hidden until auth) ─── -->
  <div id="panel" style="display:none">

    <!-- ─── Sticky tab bar ─── -->
    <nav class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-1 h-12 text-sm">
        <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-primary-700 bg-primary-50">Modifier le site</button>
        <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Fiche Google</button>
        <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Statistiques</button>
        <span class="ml-auto text-xs text-neutral-400 hidden sm:block">Espace prive — Jennifer</span>
      </div>
    </nav>

    <!-- ─── Swipeable panels ─── -->
    <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

      <!-- PANEL 1 : MODIFIER LE SITE -->
      <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0 py-10 md:py-14">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

          <!-- Header + CTA -->
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-6">
            <div>
              <h1 class="font-heading text-2xl font-bold text-neutral-900 mb-1">Modifier le site</h1>
              <p class="text-sm text-neutral-500">Cliquez sur une rubrique, modifiez les champs, puis cliquez <strong>Save</strong>.</p>
            </div>
            <a href="/keystatic/branch/dev" target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center gap-2 bg-primary-600 text-white font-medium px-5 py-2.5 rounded-xl hover:bg-primary-700 transition-colors text-sm shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              Modifier mes contenus
            </a>
          </div>

          <!-- Publier -->
          <div class="bg-green-50 border border-green-200 rounded-xl p-4 mb-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
            <div>
              <h3 class="font-semibold text-green-900 text-sm">Mettre en ligne vos modifications</h3>
              <p class="text-xs text-green-700 mt-0.5">Apres avoir modifie vos contenus, cliquez ici pour publier les changements sur votre site.</p>
            </div>
            <button type="button" id="publish-btn" onclick="publish()" class="shrink-0 inline-flex items-center gap-2 bg-green-600 text-white font-medium px-5 py-2.5 rounded-xl hover:bg-green-700 transition-colors text-sm shadow-sm">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
              Publier
            </button>
          </div>
          <p id="publish-status" class="text-sm mb-6 hidden"></p>

          <!-- Lien Personas -->
          <a href="/aide-personas" class="group mb-8 bg-accent-50 border-2 border-accent-200 rounded-xl p-4 flex items-center gap-4 hover:border-accent-400 hover:shadow-sm transition-all block">
            <div class="flex items-center justify-center w-10 h-10 bg-accent-100 text-accent-700 rounded-lg group-hover:bg-accent-200 transition-colors shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-neutral-900 text-sm">Qui visite votre site ? — 20 profils de visiteurs</h3>
              <p class="text-xs text-neutral-500 mt-0.5">Parcours, questions et recommandations pour ameliorer votre site.</p>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent-400 group-hover:text-accent-600 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          </a>

          <!-- COLLECTIONS -->
          <div class="mb-10">
            <div class="flex items-center gap-2 mb-4">
              <h2 class="text-xs font-semibold text-neutral-400 uppercase tracking-wider">Collections</h2>
              <span class="text-[10px] bg-green-100 text-green-700 font-medium px-2 py-0.5 rounded-full">Ajout & suppression possibles</span>
            </div>
            <div class="grid sm:grid-cols-2 gap-3">
              <a href="/keystatic/branch/dev/collection/blog" target="_blank" rel="noopener noreferrer" class="group bg-white border-2 border-primary-200 rounded-xl p-4 hover:border-primary-400 hover:shadow-sm transition-all">
                <div class="flex items-center gap-3 mb-3">
                  <div class="flex items-center justify-center w-9 h-9 bg-primary-50 text-primary-600 rounded-lg group-hover:bg-primary-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
                  </div>
                  <h3 class="font-semibold text-neutral-900 text-sm">Articles de blog</h3>
                </div>
                <p class="text-xs text-neutral-500 mb-2">5 articles publies</p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Titre</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Description</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Date</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Categorie</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Contenu</span>
                </div>
              </a>
              <a href="/keystatic/branch/dev/collection/services" target="_blank" rel="noopener noreferrer" class="group bg-white border border-neutral-200 rounded-xl p-4 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center gap-3 mb-3">
                  <div class="flex items-center justify-center w-9 h-9 bg-primary-50 text-primary-600 rounded-lg group-hover:bg-primary-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                  </div>
                  <h3 class="font-semibold text-neutral-900 text-sm">Services / Ateliers</h3>
                </div>
                <p class="text-xs text-neutral-500 mb-2">6 prestations actuellement</p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Titre</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Public</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Description</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Tarif</span>
                </div>
              </a>
              <a href="/keystatic/branch/dev/collection/testimonials" target="_blank" rel="noopener noreferrer" class="group bg-white border border-neutral-200 rounded-xl p-4 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center gap-3 mb-3">
                  <div class="flex items-center justify-center w-9 h-9 bg-primary-50 text-primary-600 rounded-lg group-hover:bg-primary-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                  </div>
                  <h3 class="font-semibold text-neutral-900 text-sm">Temoignages</h3>
                </div>
                <p class="text-xs text-neutral-500 mb-2">3 avis publies</p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Auteur</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Contexte</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Citation</span>
                </div>
              </a>
              <a href="/keystatic/branch/dev/collection/faq" target="_blank" rel="noopener noreferrer" class="group bg-white border border-neutral-200 rounded-xl p-4 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center gap-3 mb-3">
                  <div class="flex items-center justify-center w-9 h-9 bg-primary-50 text-primary-600 rounded-lg group-hover:bg-primary-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <h3 class="font-semibold text-neutral-900 text-sm">FAQ</h3>
                </div>
                <p class="text-xs text-neutral-500 mb-2">8 questions/reponses</p>
                <div class="flex flex-wrap gap-1.5">
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Question</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">Reponse</span>
                </div>
              </a>
            </div>
          </div>

          <!-- SINGLETONS -->
          <div class="mb-10">
            <div class="flex items-center gap-2 mb-4">
              <h2 class="text-xs font-semibold text-neutral-400 uppercase tracking-wider">Sections uniques</h2>
              <span class="text-[10px] bg-neutral-100 text-neutral-500 font-medium px-2 py-0.5 rounded-full">Modification uniquement</span>
            </div>
            <div class="grid sm:grid-cols-2 gap-3">
              <a href="/keystatic/branch/dev/singleton/siteInfo" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 bg-white border border-neutral-200 rounded-xl px-4 py-3 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-center w-8 h-8 bg-neutral-100 text-neutral-500 rounded-lg group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-neutral-900 text-sm">Informations generales</h3>
                  <p class="text-xs text-neutral-400">Nom, telephone, email, adresse, reseaux sociaux</p>
                </div>
              </a>
              <a href="/keystatic/branch/dev/singleton/hero" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 bg-white border border-neutral-200 rounded-xl px-4 py-3 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-center w-8 h-8 bg-neutral-100 text-neutral-500 rounded-lg group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-neutral-900 text-sm">Bandeau d'accueil</h3>
                  <p class="text-xs text-neutral-400">Titre, sous-titre, boutons, phrase de reassurance</p>
                </div>
              </a>
              <a href="/keystatic/branch/dev/singleton/about" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 bg-white border border-neutral-200 rounded-xl px-4 py-3 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-center w-8 h-8 bg-neutral-100 text-neutral-500 rounded-lg group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-neutral-900 text-sm">A propos</h3>
                  <p class="text-xs text-neutral-400">Votre parcours, fiches animaux (Tips, Uxo, Tap-Tap)</p>
                </div>
              </a>
              <a href="/keystatic/branch/dev/singleton/contact" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 bg-white border border-neutral-200 rounded-xl px-4 py-3 hover:border-primary-300 hover:shadow-sm transition-all">
                <div class="flex items-center justify-center w-8 h-8 bg-neutral-100 text-neutral-500 rounded-lg group-hover:bg-primary-50 group-hover:text-primary-600 transition-colors shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <h3 class="font-medium text-neutral-900 text-sm">Section contact</h3>
                  <p class="text-xs text-neutral-400">Titre, texte d'introduction, texte du bouton</p>
                </div>
              </a>
            </div>
          </div>

          <!-- Conseils -->
          <div class="bg-amber-50/70 border border-amber-200 rounded-xl px-4 py-3 text-sm text-neutral-700 flex items-start gap-2">
            <span class="text-amber-400 mt-0.5 shrink-0">&#9888;</span>
            <div>
              <strong class="text-amber-800">N'oubliez pas Save</strong> apres chaque modification. En cas d'erreur, pas de panique : les versions precedentes sont conservees.
              Pour les photos ou le design, <a href="mailto:marc@muller.im" class="text-primary-600 underline">contactez-moi</a>.
            </div>
          </div>

        </div>
      </section>

      <!-- PANEL 2 : FICHE GOOGLE -->
      <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0 py-10 md:py-14">
        <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

          <h1 class="font-heading text-2xl font-bold text-neutral-900 mb-1">Votre fiche Google</h1>
          <p class="text-sm text-neutral-500 mb-8">Plus votre fiche est complete et a d'avis, plus vous etes visible sur Google.</p>

          <div class="grid sm:grid-cols-2 gap-5 mb-8">
            <div class="bg-white border border-neutral-200 rounded-xl p-5">
              <div class="flex items-center justify-center w-9 h-9 bg-blue-50 text-blue-600 rounded-lg mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <h3 class="font-semibold text-neutral-900 text-sm mb-1">Gerer votre fiche</h3>
              <p class="text-xs text-neutral-500 mb-3">Horaires, photos, actualites, reponses aux avis.</p>
              <a href="https://business.google.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-blue-600 font-medium text-xs hover:text-blue-700 transition-colors">
                Ouvrir Google Business
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            </div>
            <div class="bg-white border border-neutral-200 rounded-xl p-5">
              <div class="flex items-center justify-center w-9 h-9 bg-amber-50 text-amber-600 rounded-lg mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
              </div>
              <h3 class="font-semibold text-neutral-900 text-sm mb-1">Demander un avis</h3>
              <p class="text-xs text-neutral-500 mb-3">Envoyez ce lien par SMS apres une seance :</p>
              <div class="flex items-center gap-2">
                <input type="text" readonly value="https://search.google.com/local/writereview?placeid=Cgj5KKd-mumURxIIOMig01Ww6gY" class="w-full text-xs bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-500 select-all" id="review-link" />
                <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('review-link').value);this.textContent='OK';setTimeout(()=>this.textContent='Copier',2000)" class="shrink-0 bg-amber-500 text-white text-xs font-medium px-3 py-2 rounded-lg hover:bg-amber-600 transition-colors">Copier</button>
              </div>
            </div>
          </div>

          <div class="bg-blue-50/50 border border-blue-200 rounded-xl px-4 py-3 text-sm text-neutral-700">
            <span class="font-semibold text-blue-800">Astuces :</span>
            Demandez un avis juste apres la seance. Envoyez le lien par SMS (plus efficace qu'un email). Repondez a chaque avis, meme un simple "Merci".
          </div>

        </div>
      </section>

      <!-- PANEL 3 : STATISTIQUES -->
      <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0 py-10 md:py-14">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
            <div>
