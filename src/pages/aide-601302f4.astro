  <script is:inline>
    const HASH = 'b141e8d004f7e3f30db42b95dbcadd13aefcbcb7a1a763a52e6a800a45263cf7';

    /* ── Password gate ── */
    async function checkPwd(e) {
      e.preventDefault();
      const pwd = document.getElementById('pwd').value;
      const encoded = new TextEncoder().encode(pwd);
      const hashBuffer = await crypto.subtle.digest('SHA-256', encoded);
      const hashHex = [...new Uint8Array(hashBuffer)].map(b => b.toString(16).padStart(2, '0')).join('');
      if (hashHex === HASH) {
        sessionStorage.setItem('aide-auth', '1');
        showPanel();
      } else {
        document.getElementById('gate-error').classList.remove('hidden');
      }
    }

    function showPanel() {
      document.getElementById('gate').style.display = 'none';
      document.getElementById('panel').style.display = 'block';
      initTabs();
    }

    document.getElementById('gate-form').addEventListener('submit', checkPwd);
    if (sessionStorage.getItem('aide-auth') === '1') showPanel();

    /* ── Publish API ── */
    async function publish() {
      const btn = document.getElementById('publish-btn');
      const status = document.getElementById('publish-status');
      btn.disabled = true;
      btn.textContent = 'Publication en cours...';
      status.classList.remove('hidden', 'text-green-600', 'text-red-500');
      status.textContent = '';
      try {
        const res = await fetch('/api/publish', { method: 'POST' });
        const data = await res.json();
        if (data.ok) {
          status.textContent = 'Publie ! Le site sera mis a jour dans environ 2 minutes.';
          status.classList.add('text-green-600');
        } else {
          status.textContent = 'Erreur : ' + (data.error || 'Erreur inconnue');
          status.classList.add('text-red-500');
        }
      } catch (e) {
        status.textContent = 'Erreur : ' + e.message;
        status.classList.add('text-red-500');
      }
      status.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Publier';
    }

    /* ── Tab + swipe sync ── */
    function initTabs() {
      const panels = document.getElementById('panels');
      if (!panels) return;
      const tabs = document.querySelectorAll('.tab-btn');
      const sections = panels.querySelectorAll('.tab-panel');

      function activateTab(index) {
        tabs.forEach((b, i) => {
          if (i === index) {
            b.classList.remove('text-neutral-500');
            b.classList.add('text-primary-700', 'bg-primary-50');
          } else {
            b.classList.remove('text-primary-700', 'bg-primary-50');
            b.classList.add('text-neutral-500');
          }
        });
      }

      tabs.forEach((btn, i) => {
        btn.addEventListener('click', () => {
          sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
          activateTab(i);
        });
      });

      let scrollTimeout;
      panels.addEventListener('scroll', () => {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          const scrollLeft = panels.scrollLeft;
          const panelWidth = panels.offsetWidth;
          const index = Math.round(scrollLeft / panelWidth);
          activateTab(index);
        }, 50);
      }, { passive: true });
    }
  </script>
