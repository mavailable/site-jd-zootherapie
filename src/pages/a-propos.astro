---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import About from '@components/sections/About.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
---

<BaseLayout
  title="Jennifer De Groeve — Praticienne en médiation animale, Moselle"
  description="Aide-soignante diplômée reconvertie, Jennifer De Groeve allie 20 ans d'expérience du soin et sa passion pour les animaux. Praticienne certifiée IFZ, Moselle."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://jdzootherapeute.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Mon parcours", "item": "https://jdzootherapeute.fr/a-propos" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1="Jennifer De Groeve — Une vocation née du soin et de l'amour des animaux"
    subtitle="Aide-soignante diplômée, praticienne certifiée en médiation animale, membre du Syndicat Français des Zoothérapeutes — Jennifer a fait de ses deux passions un métier."
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">Mon parcours</li>
      </ol>
    </div>
  </nav>

  <!-- About complet : tous les paragraphes + section animaux -->
  <About snippet={false} />

  <CTABanner
    title="Envie de nous rencontrer ?"
    text="Jennifer et ses animaux se déplacent à domicile ou dans votre structure. Premier échange gratuit."
    ctaText="Appeler Jennifer"
    ctaSecondaryText="Voir les ateliers"
    ctaSecondaryHref="/ateliers"
  />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
