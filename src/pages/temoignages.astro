---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
import { getTestimonials } from '@data/content';

const testimonials = getTestimonials();
---

<BaseLayout
  title="Témoignages — Familles et structures en Moselle | JD Zoothérapie"
  description="Témoignages de familles, équipes soignantes et structures ayant fait appel à JD Zoothérapie en Moselle. Des résultats concrets, des sourires réels."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://jd-zootherapie.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Témoignages", "item": "https://jd-zootherapie.fr/temoignages" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1="Ce que disent ceux qui ont fait appel à Jennifer"
    subtitle="Témoignages de familles, de structures et d'équipes soignantes qui ont expérimenté la médiation animale avec JD Zoothérapie."
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">Témoignages</li>
      </ol>
    </div>
  </nav>

  <!-- Témoignages — fond blanc, grille large cards -->
  <section class="bg-white py-14 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <article class="bg-secondary-50 border border-secondary-200 rounded-xl p-6 flex flex-col">
            <svg class="w-8 h-8 text-secondary-400 mb-3 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z"/>
            </svg>
            <blockquote class="text-neutral-700 text-sm leading-relaxed mb-5 flex-1 italic">
              {t.quote}
            </blockquote>
            <footer class="border-t border-secondary-200 pt-4 mt-auto">
              <p class="font-semibold text-primary-900 text-sm">{t.author}</p>
              <p class="text-neutral-500 text-xs mt-0.5">{t.context}</p>
            </footer>
          </article>
        ))}
      </div>

      <!-- Note collecte témoignages -->
      <div class="mt-10 p-5 bg-neutral-50 border border-neutral-200 rounded-xl text-center">
        <p class="text-neutral-600 text-sm">
          D'autres témoignages seront ajoutés prochainement. Vous avez fait appel à Jennifer ?
          <a href="/contact" class="text-primary-600 hover:text-primary-800 font-medium underline underline-offset-2 transition-colors ml-1">Partagez votre expérience</a>
        </p>
      </div>
    </div>
  </section>

  <!-- Section presse — fond primary-50 -->
  <section class="bg-primary-50 py-14 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading font-semibold text-xl md:text-2xl text-primary-900 mb-8">
        La médiation animale dans la presse
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <article class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
            <span class="text-xs text-neutral-400 font-medium">Bibliothèque de Marly</span>
          </div>
          <h3 class="font-heading font-semibold text-base text-primary-900 mb-2">
            "Et si un chien aidait vos enfants à lire ?"
          </h3>
          <p class="text-neutral-700 text-sm leading-relaxed">Atelier de lecture assistée par l'animal avec Tips et Uxo. Un format innovant qui attire les enfants qui n'aiment pas lire.</p>
        </article>
        <article class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
          <div class="flex items-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
            <span class="text-xs text-neutral-400 font-medium">Presse locale Moselle</span>
          </div>
          <h3 class="font-heading font-semibold text-base text-primary-900 mb-2">
            La médiation animale à l'honneur
          </h3>
          <p class="text-neutral-700 text-sm leading-relaxed">Article de presse consacré à l'engagement de Jennifer et à l'impact de ses interventions sur le terrain.</p>
        </article>
      </div>
    </div>
  </section>

  <CTABanner
    title="Prêt à vivre l'expérience ?"
    text="Premier échange téléphonique gratuit pour construire votre projet de médiation animale."
    ctaText="Appeler Jennifer"
    ctaSecondaryText="Voir les ateliers"
    ctaSecondaryHref="/ateliers"
  />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
