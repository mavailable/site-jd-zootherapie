---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import Services from '@components/sections/Services.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
---

<BaseLayout
  title="Ateliers de médiation animale en Moselle | JD Zoothérapie"
  description="6 types d'ateliers adaptés à chaque public : seniors, enfants, maladies neurodégénératives, familles, aidants. Interventions en Moselle. Devis gratuit."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://jd-zootherapie.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Les ateliers", "item": "https://jd-zootherapie.fr/ateliers" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1="Des ateliers de médiation animale adaptés à chaque situation"
    subtitle="Particuliers, familles ou structures — Jennifer De Groeve propose des interventions sur mesure, avec ses animaux médiateurs, à Metz, Thionville et dans toute la Moselle."
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">Les ateliers</li>
      </ol>
    </div>
  </nav>

  <!-- Tous les ateliers via composant Services -->
  <Services
    title="Choisissez votre atelier"
    subtitle="Particuliers, familles ou structures — chaque séance est construite autour de vos objectifs, en douceur et en confiance, avec des animaux médiateurs formés."
    showCTA={false}
  />

  <!-- Zone d'intervention — fond blanc, layout asymétrique -->
  <section class="bg-white py-14 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
        <div>
          <h2 class="font-heading font-semibold text-xl md:text-2xl text-primary-900 mb-5">
            Zone d'intervention
          </h2>
          <div class="space-y-4 text-neutral-700 text-sm leading-relaxed">
            <div class="flex items-start gap-3 p-4 bg-primary-50 rounded-xl border border-primary-100">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-600 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <div>
                <p class="font-semibold text-primary-900 mb-1">Rayon principal : 15 km autour de Verny</p>
                <p>Déplacement inclus dans le tarif de la séance. Jennifer se déplace à domicile ou dans votre structure.</p>
              </div>
            </div>
            <div class="flex items-start gap-3 p-4 bg-neutral-50 rounded-xl border border-neutral-200">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-neutral-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
              <div>
                <p class="font-semibold text-neutral-800 mb-1">Au-delà : 0,50 €/km</p>
                <p class="text-neutral-600">Interventions ponctuelles possibles jusqu'à Metz et Nancy sur demande.</p>
              </div>
            </div>
          </div>
        </div>
        <!-- Encart comment ça se passe -->
        <div class="bg-secondary-50 border border-secondary-200 rounded-2xl p-7">
          <h3 class="font-heading font-semibold text-lg text-secondary-900 mb-3">Comment se déroule une première séance ?</h3>
          <ol class="space-y-3">
            {[
              'Un premier échange téléphonique gratuit pour comprendre votre situation et vos objectifs',
              'Jennifer prépare une intervention sur mesure avec le ou les animaux adaptés',
              'La première rencontre est douce et progressive — pas d\'obligation, pas de performance',
              'Un bilan est réalisé après chaque séance pour suivre les progrès',
            ].map((step, i) => (
              <li class="flex items-start gap-3 text-sm text-neutral-700">
                <span class="inline-flex items-center justify-center w-6 h-6 bg-secondary-300 text-secondary-900 rounded-full text-xs font-bold shrink-0 mt-0.5">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    title="Vous ne savez pas quel atelier choisir ?"
    text="Appelez Jennifer pour un premier échange gratuit. Elle vous guidera vers la formule la plus adaptée."
    ctaText="Je prends contact"
    ctaHref="/contact"
    ctaSecondaryText="Voir les tarifs"
    ctaSecondaryHref="/tarifs"
  />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
