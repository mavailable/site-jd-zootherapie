---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
import TarifCalculator from '@components/sections/TarifCalculator.astro';
---

<BaseLayout
  title="Tarifs — Médiation animale à domicile | JD Zoothérapie"
  description="Séance individuelle à 60 €, déplacement inclus (rayon 15 km Verny). Groupes et structures sur devis. Transparent, sans surprise. Jennifer De Groeve."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://jd-zootherapie.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Tarifs", "item": "https://jd-zootherapie.fr/tarifs" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1="Tarifs de médiation animale — Transparence et accompagnement sur mesure"
    subtitle="Chaque rencontre est unique. Jennifer construit ses interventions autour de vos besoins réels, pas d'un chronomètre."
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">Tarifs</li>
      </ol>
    </div>
  </nav>

  <!-- Grille tarifaire — fond blanc, cards max-w-3xl -->
  <section class="bg-white py-14 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-5">

        <!-- Séance individuelle — mise en avant -->
        <article class="bg-primary-50 border-2 border-primary-300 rounded-2xl p-7 relative overflow-hidden">
          <div class="absolute top-4 right-4">
            <span class="inline-flex items-center gap-1 bg-accent-700 text-white text-xs font-semibold px-3 py-1 rounded-full">
              Le plus choisi
            </span>
          </div>
          <div class="flex items-start gap-5">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-primary-200 text-primary-700 rounded-xl shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="flex-1">
              <div class="flex items-baseline gap-3 flex-wrap mb-2">
                <h2 class="font-heading font-semibold text-xl text-primary-900">Séance individuelle</h2>
                <span class="font-heading font-bold text-2xl text-accent-700">60 €</span>
              </div>
              <p class="text-neutral-700 text-sm leading-relaxed mb-4">Un temps dédié, en douceur et en confiance. Chaque séance est construite autour de vos objectifs personnels : soutien émotionnel, développement moteur ou cognitif, gestion des émotions.</p>
              <ul class="space-y-1.5">
                {['Durée adaptée à la personne accompagnée', 'Déplacement inclus en Moselle', 'Facture fournie sur demande'].map((item) => (
                  <li class="flex items-center gap-2 text-sm text-neutral-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-500 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>

        <!-- Séances de groupe -->
        <article class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
          <div class="flex items-start gap-5">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-secondary-100 text-secondary-700 rounded-xl shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="flex-1">
              <div class="flex items-baseline gap-3 flex-wrap mb-2">
                <h2 class="font-heading font-semibold text-lg text-primary-900">Séances de groupe</h2>
                <span class="font-semibold text-neutral-600">Tarif sur projet</span>
              </div>
              <p class="text-neutral-700 text-sm leading-relaxed mb-4">Chaque groupe est différent. Le tarif est établi en fonction du nombre de participants, de la durée, des objectifs et de la fréquence des séances. Jennifer co-construit le projet avec votre équipe.</p>
              <ul class="space-y-1.5">
                {['EHPAD, IME, foyers, écoles, bibliothèques', 'Devis gratuit, sans engagement'].map((item) => (
                  <li class="flex items-center gap-2 text-sm text-neutral-700">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-neutral-400 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </article>

        <!-- Accompagnement sur mesure -->
        <article class="bg-white border border-neutral-200 rounded-xl p-6 shadow-sm">
          <div class="flex items-start gap-5">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-accent-100 text-accent-700 rounded-xl shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/></svg>
            </div>
            <div class="flex-1">
              <div class="flex items-baseline gap-3 flex-wrap mb-2">
                <h2 class="font-heading font-semibold text-lg text-primary-900">Accompagnement sur mesure</h2>
                <span class="font-semibold text-neutral-600">Sur devis</span>
              </div>
              <p class="text-neutral-700 text-sm leading-relaxed">Pour les structures qui souhaitent intégrer la médiation animale dans leur projet d'établissement. Parcours mêlant séances individuelles et collectives, suivi régulier et évolutif.</p>
            </div>
          </div>
        </article>

        <!-- Déplacement -->
        <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-5 flex items-start gap-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-neutral-500 mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <div class="text-sm text-neutral-700">
            <p class="font-semibold text-neutral-800 mb-1">Déplacement</p>
            <p>Interventions à Metz, Thionville et dans toute la Moselle. Au-delà : 0,40 €/km selon la distance. Utilisez le simulateur pour connaître le tarif exact.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Calculateur de tarif -->
  <TarifCalculator />

  <CTABanner
    title="Demander un devis gratuit"
    text="Premier échange par téléphone pour comprendre votre situation et vous proposer une formule adaptée."
    ctaText="Appeler Jennifer"
    ctaSecondaryText="Envoyer un message"
    ctaSecondaryHref="/contact"
  />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
