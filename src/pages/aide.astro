---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Aide — Votre espace administration"
  description="Guide pour modifier le contenu de votre site et consulter vos statistiques."
  noindex={true}
>
  <Header slot="header" />

  <!-- ─── Sticky tab bar ─── -->
  <nav class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-1 h-12 text-sm overflow-x-auto">
      <button data-tab="modifier" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-primary-700 bg-primary-50">Modifier le site</button>
      <button data-tab="google" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Fiche Google</button>
      <button data-tab="statistiques" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Statistiques</button>
      <span class="ml-auto text-xs text-neutral-400 hidden sm:block">Espace privé — Jennifer</span>
    </div>
  </nav>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- TAB 1 : MODIFIER LE SITE                        -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="modifier" class="tab-panel py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Bouton CMS -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-10">
        <div>
          <h1 class="font-heading text-2xl font-bold text-neutral-900 mb-1">Modifier le site</h1>
          <p class="text-sm text-neutral-500">Modifiez vos textes, tarifs, témoignages et informations en quelques clics.</p>
        </div>
        <a
          href="/keystatic"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center gap-2 bg-primary-600 text-white font-medium px-5 py-2.5 rounded-xl hover:bg-primary-700 transition-colors text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Modifier mes contenus
        </a>
      </div>

      <!-- 3 étapes inline -->
      <div class="grid grid-cols-3 gap-3 mb-10 text-center">
        <div class="bg-neutral-50 rounded-lg px-3 py-3">
          <span class="inline-flex items-center justify-center w-6 h-6 bg-primary-600 text-white font-bold rounded-full text-xs mb-1.5">1</span>
          <p class="text-neutral-600 text-xs">Menu de gauche</p>
        </div>
        <div class="bg-neutral-50 rounded-lg px-3 py-3">
          <span class="inline-flex items-center justify-center w-6 h-6 bg-primary-600 text-white font-bold rounded-full text-xs mb-1.5">2</span>
          <p class="text-neutral-600 text-xs">Modifier les champs</p>
        </div>
        <div class="bg-neutral-50 rounded-lg px-3 py-3">
          <span class="inline-flex items-center justify-center w-6 h-6 bg-primary-600 text-white font-bold rounded-full text-xs mb-1.5">3</span>
          <p class="text-neutral-600 text-xs">Cliquer Save</p>
        </div>
      </div>

      <!-- Tableau récap -->
      <div class="overflow-hidden rounded-xl border border-neutral-200 mb-8">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-neutral-50 border-b border-neutral-200">
              <th class="text-left px-4 py-2.5 font-semibold text-neutral-700">Rubrique</th>
              <th class="text-left px-4 py-2.5 font-semibold text-neutral-700">Champs modifiables</th>
              <th class="text-center px-4 py-2.5 font-semibold text-neutral-700 hidden sm:table-cell">+/−</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            <tr>
              <td class="px-4 py-2.5 font-medium text-neutral-900">Services / Ateliers</td>
              <td class="px-4 py-2.5 text-neutral-600">Titre, public, description, tarif</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-green-600">Oui</span></td>
            </tr>
            <tr>
              <td class="px-4 py-2.5 font-medium text-neutral-900">Témoignages</td>
              <td class="px-4 py-2.5 text-neutral-600">Auteur, contexte, citation</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-green-600">Oui</span></td>
            </tr>
            <tr>
              <td class="px-4 py-2.5 font-medium text-neutral-900">FAQ</td>
              <td class="px-4 py-2.5 text-neutral-600">Question, réponse</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-green-600">Oui</span></td>
            </tr>
            <tr class="bg-neutral-50/50">
              <td class="px-4 py-2.5 font-medium text-neutral-900">Infos générales</td>
              <td class="px-4 py-2.5 text-neutral-600">Nom, téléphone, email, adresse, réseaux</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-neutral-300">—</span></td>
            </tr>
            <tr class="bg-neutral-50/50">
              <td class="px-4 py-2.5 font-medium text-neutral-900">Bandeau d'accueil</td>
              <td class="px-4 py-2.5 text-neutral-600">Titre, sous-titre, boutons, réassurance</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-neutral-300">—</span></td>
            </tr>
            <tr class="bg-neutral-50/50">
              <td class="px-4 py-2.5 font-medium text-neutral-900">À propos</td>
              <td class="px-4 py-2.5 text-neutral-600">Parcours, fiches animaux</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-neutral-300">—</span></td>
            </tr>
            <tr class="bg-neutral-50/50">
              <td class="px-4 py-2.5 font-medium text-neutral-900">Contact</td>
              <td class="px-4 py-2.5 text-neutral-600">Titre, texte intro, bouton</td>
              <td class="px-4 py-2.5 text-center hidden sm:table-cell"><span class="text-neutral-300">—</span></td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Conseils compacts -->
      <div class="bg-amber-50/70 border border-amber-200 rounded-xl px-4 py-3 text-sm text-neutral-700">
        <span class="font-semibold text-amber-800">Bon à savoir :</span>
        Cliquez Save après chaque modif. En cas d'erreur, les anciennes versions sont conservées.
        Pour les photos ou le design, contactez-moi.
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- TAB 2 : FICHE GOOGLE                            -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="google" class="tab-panel hidden py-10 md:py-14">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <h1 class="font-heading text-2xl font-bold text-neutral-900 mb-1">Votre fiche Google</h1>
      <p class="text-sm text-neutral-500 mb-8">Plus votre fiche est complète et a d'avis, plus vous êtes visible sur Google.</p>

      <div class="grid sm:grid-cols-2 gap-5 mb-8">
        <!-- Gérer la fiche -->
        <div class="bg-white border border-neutral-200 rounded-xl p-5">
          <div class="flex items-center justify-center w-9 h-9 bg-blue-50 text-blue-600 rounded-lg mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="font-semibold text-neutral-900 text-sm mb-1">Gérer votre fiche</h3>
          <p class="text-xs text-neutral-500 mb-3">Horaires, photos, actualités, réponses aux avis.</p>
          <a href="https://business.google.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-blue-600 font-medium text-xs hover:text-blue-700 transition-colors">
            Ouvrir Google Business
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>

        <!-- Demander un avis -->
        <div class="bg-white border border-neutral-200 rounded-xl p-5">
          <div class="flex items-center justify-center w-9 h-9 bg-amber-50 text-amber-600 rounded-lg mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4.5 h-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
          </div>
          <h3 class="font-semibold text-neutral-900 text-sm mb-1">Demander un avis</h3>
          <p class="text-xs text-neutral-500 mb-3">Envoyez ce lien par SMS après une séance :</p>
          <div class="flex items-center gap-2">
            <input type="text" readonly value="https://search.google.com/local/writereview?placeid=Cgj5KKd-mumURxIIOMig01Ww6gY" class="w-full text-xs bg-neutral-50 border border-neutral-200 rounded-lg px-3 py-2 text-neutral-500 select-all" id="review-link" />
            <button type="button" onclick="navigator.clipboard.writeText(document.getElementById('review-link').value);this.textContent='OK';setTimeout(()=>this.textContent='Copier',2000)" class="shrink-0 bg-amber-500 text-white text-xs font-medium px-3 py-2 rounded-lg hover:bg-amber-600 transition-colors">Copier</button>
          </div>
        </div>
      </div>

      <!-- Astuces -->
      <div class="bg-blue-50/50 border border-blue-200 rounded-xl px-4 py-3 text-sm text-neutral-700">
        <span class="font-semibold text-blue-800">Astuces :</span>
        Demandez un avis juste après la séance. Envoyez le lien par SMS (plus efficace qu'un email). Répondez à chaque avis, même un simple "Merci".
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- TAB 3 : STATISTIQUES                            -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="statistiques" class="tab-panel hidden py-10 md:py-14">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
          <h1 class="font-heading text-2xl font-bold text-neutral-900 mb-1">Statistiques de visites</h1>
          <p class="text-sm text-neutral-500">Visiteurs, pages vues, sources de trafic — en temps réel, 100 % anonyme.</p>
        </div>
        <a href="https://cloud.umami.is/share/7qxMncBLuGRFA5uK" target="_blank" rel="noopener noreferrer" class="shrink-0 inline-flex items-center gap-2 bg-white text-primary-600 font-medium px-4 py-2 rounded-lg border border-primary-200 hover:bg-primary-50 transition-colors text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Plein écran
        </a>
      </div>

      <div class="rounded-xl overflow-hidden border border-neutral-200 bg-white shadow-sm">
        <iframe
          src="https://cloud.umami.is/share/7qxMncBLuGRFA5uK"
          class="w-full border-0"
          style="height: 750px;"
          title="Statistiques du site jdzootherapeute.fr"
          loading="lazy"
        ></iframe>
      </div>

    </div>
  </section>

  <!-- ─── Contact webmaster ─── -->
  <div class="text-center py-6 border-t border-neutral-100 text-xs text-neutral-400">
    Besoin d'aide ?
    <a href="mailto:marc@marc-muller.com" class="text-primary-600 font-medium hover:text-primary-700 transition-colors">marc@marc-muller.com</a>
  </div>

  <Footer slot="footer" />

  <!-- Tab switching -->
  <script is:inline>
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.tab;
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
        document.getElementById(target).classList.remove('hidden');
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('text-primary-700', 'bg-primary-50');
          b.classList.add('text-neutral-500');
        });
        btn.classList.remove('text-neutral-500');
        btn.classList.add('text-primary-700', 'bg-primary-50');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  </script>
</BaseLayout>
