---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Aide — Modifier votre site"
  description="Guide pour modifier le contenu de votre site JD Zoothérapie."
  noindex={true}
>
  <Header slot="header" />

  <!-- Hero compact -->
  <section class="bg-primary-50 py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-3">
        Espace administration
      </h1>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
        Bienvenue Jennifer ! Depuis cette page, vous pouvez modifier votre site et consulter vos statistiques de visites.
      </p>

      <!-- Navigation rapide -->
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        <a href="#modifier" class="inline-flex items-center gap-2 bg-white text-primary-700 font-medium px-5 py-2.5 rounded-lg border border-primary-200 hover:bg-primary-100 transition-colors text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Modifier le site
        </a>
        <a href="#statistiques" class="inline-flex items-center gap-2 bg-white text-primary-700 font-medium px-5 py-2.5 rounded-lg border border-primary-200 hover:bg-primary-100 transition-colors text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          Voir les statistiques
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SECTION 1 : MODIFIER LE SITE               -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="modifier" class="py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex items-center gap-3 mb-2">
        <div class="flex items-center justify-center w-10 h-10 bg-primary-100 text-primary-600 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Modifier le site</h2>
      </div>
      <p class="text-neutral-500 mb-8 ml-13">Modifiez vos textes, tarifs, témoignages et informations en quelques clics.</p>

      <!-- Bouton CMS -->
      <a
        href="/keystatic"
        class="inline-flex items-center gap-2 bg-primary-600 text-white font-medium px-6 py-3 rounded-xl hover:bg-primary-700 transition-colors mb-10"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        Ouvrir l'administration du site
      </a>

      <!-- 3 étapes -->
      <div class="grid md:grid-cols-3 gap-4 mb-12">
        <div class="bg-white border border-neutral-200 rounded-xl p-5 text-center">
          <span class="inline-flex items-center justify-center w-10 h-10 bg-primary-100 text-primary-700 font-bold rounded-full text-sm mb-3">1</span>
          <p class="text-neutral-700 text-sm">Cliquez sur l'élément à modifier dans le <strong>menu de gauche</strong></p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-xl p-5 text-center">
          <span class="inline-flex items-center justify-center w-10 h-10 bg-primary-100 text-primary-700 font-bold rounded-full text-sm mb-3">2</span>
          <p class="text-neutral-700 text-sm">Modifiez les champs souhaités (textes, prix, descriptions...)</p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-xl p-5 text-center">
          <span class="inline-flex items-center justify-center w-10 h-10 bg-primary-100 text-primary-700 font-bold rounded-full text-sm mb-3">3</span>
          <p class="text-neutral-700 text-sm">Cliquez sur <strong>Save</strong> — les modifications sont en ligne en quelques minutes</p>
        </div>
      </div>

      <!-- Deux colonnes : Collections + Singletons -->
      <div class="grid md:grid-cols-2 gap-8">

        <!-- Colonne gauche : Collections -->
        <div>
          <h3 class="text-lg font-bold text-neutral-900 mb-1">Collections</h3>
          <p class="text-sm text-neutral-500 mb-4">Listes d'éléments que vous pouvez ajouter, modifier ou supprimer.</p>

          <div class="space-y-4">
            <!-- Services -->
            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-2">Services / Ateliers</h4>
              <ul class="space-y-1 text-sm text-neutral-600">
                <li><span class="text-primary-500">&#10003;</span> <strong>Titre</strong> — nom du service</li>
                <li><span class="text-primary-500">&#10003;</span> <strong>Public</strong> — à qui il s'adresse</li>
                <li><span class="text-primary-500">&#10003;</span> <strong>Description</strong> — texte de présentation</li>
                <li><span class="text-primary-500">&#10003;</span> <strong>Tarif</strong> — prix affiché</li>
              </ul>
            </div>

            <!-- Témoignages -->
            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-2">Témoignages</h4>
              <ul class="space-y-1 text-sm text-neutral-600">
                <li><span class="text-primary-500">&#10003;</span> <strong>Auteur</strong> — prénom et initiale</li>
                <li><span class="text-primary-500">&#10003;</span> <strong>Contexte</strong> — situation de l'auteur</li>
                <li><span class="text-primary-500">&#10003;</span> <strong>Citation</strong> — texte de l'avis</li>
              </ul>
              <p class="text-xs text-neutral-400 mt-2">Bouton "Create" pour en ajouter un nouveau.</p>
            </div>

            <!-- FAQ -->
            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-2">FAQ</h4>
              <ul class="space-y-1 text-sm text-neutral-600">
                <li><span class="text-primary-500">&#10003;</span> <strong>Question</strong> — la question posée</li>
                <li><span class="text-primary-500">&#10003;</span> <strong>Réponse</strong> — le texte de la réponse</li>
              </ul>
              <p class="text-xs text-neutral-400 mt-2">Vous pouvez ajouter, modifier ou supprimer des questions.</p>
            </div>
          </div>
        </div>

        <!-- Colonne droite : Singletons -->
        <div>
          <h3 class="text-lg font-bold text-neutral-900 mb-1">Sections uniques</h3>
          <p class="text-sm text-neutral-500 mb-4">Pages qui existent en un seul exemplaire. Modifiez leur contenu.</p>

          <div class="space-y-4">
            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-1">Informations générales</h4>
              <p class="text-sm text-neutral-600">Nom, téléphone, email, adresse, zone d'intervention, réseaux sociaux.</p>
            </div>

            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-1">Section Hero (Accueil)</h4>
              <p class="text-sm text-neutral-600">Titre principal, sous-titre, boutons d'appel à l'action, phrase de réassurance.</p>
            </div>

            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-1">Section À Propos</h4>
              <p class="text-sm text-neutral-600">Votre parcours, présentation, et les fiches de vos animaux (Tips, Uxo, Tap-Tap).</p>
            </div>

            <div class="bg-white border border-neutral-200 rounded-xl p-4">
              <h4 class="font-semibold text-neutral-900 mb-1">Section Contact</h4>
              <p class="text-sm text-neutral-600">Titre, texte d'introduction, texte du bouton d'envoi.</p>
            </div>
          </div>
        </div>

      </div>

      <!-- Conseils -->
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-6 mt-10">
        <h3 class="font-semibold text-amber-800 mb-3">Bon à savoir</h3>
        <div class="grid sm:grid-cols-2 gap-3 text-sm text-neutral-700">
          <div class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5 shrink-0">&#9679;</span>
            <span>Pensez à <strong>sauvegarder</strong> après chaque modification (bouton Save).</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5 shrink-0">&#9679;</span>
            <span>Pas de panique : les anciennes versions sont conservées. Contactez-moi pour restaurer.</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5 shrink-0">&#9679;</span>
            <span>Pour les <strong>photos, le design ou la structure</strong>, contactez-moi directement.</span>
          </div>
          <div class="flex items-start gap-2">
            <span class="text-amber-500 mt-0.5 shrink-0">&#9679;</span>
            <span>En cas de doute, n'hésitez pas : mieux vaut demander !</span>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SECTION 2 : STATISTIQUES                    -->
  <!-- ═══════════════════════════════════════════ -->
  <section id="statistiques" class="bg-neutral-50 py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <div class="flex items-center gap-3 mb-2">
        <div class="flex items-center justify-center w-10 h-10 bg-primary-100 text-primary-600 rounded-xl">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900">Statistiques de visites</h2>
      </div>
      <p class="text-neutral-500 mb-8 ml-13">Visiteurs, pages vues, sources de trafic — en temps réel, 100 % anonyme, sans cookies.</p>

      <!-- Iframe stats -->
      <div class="rounded-2xl overflow-hidden border border-neutral-200 bg-white shadow-sm">
        <iframe
          src="https://cloud.umami.is/share/7qxMncBLuGRFA5uK"
          class="w-full border-0"
          style="height: 700px;"
          title="Statistiques du site jdzootherapeute.fr"
          loading="lazy"
        ></iframe>
      </div>
      <p class="mt-4 text-center">
        <a
          href="https://cloud.umami.is/share/7qxMncBLuGRFA5uK"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-primary-600 font-medium hover:text-primary-700 transition-colors text-sm"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Ouvrir les statistiques en plein écran
        </a>
      </p>

    </div>
  </section>

  <!-- Contact webmaster -->
  <section class="py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-neutral-500 text-sm">
        Une question ? Un souci ? Contactez votre webmaster :
      </p>
      <p class="mt-2">
        <a href="mailto:marc@marc-muller.com" class="text-primary-600 font-medium hover:text-primary-700 transition-colors">
          marc@marc-muller.com
        </a>
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
