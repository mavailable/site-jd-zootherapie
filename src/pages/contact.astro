---

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import PageHero from '@components/sections/PageHero.astro';
import Contact from '@components/sections/Contact.astro';
import TarifCalculator from '@components/sections/TarifCalculator.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
---

<BaseLayout
  title="Contact — JD Zoothérapie | Jennifer De Groeve, Verny Moselle"
  description="Contactez Jennifer De Groeve pour un premier échange gratuit. Appelez le 07 54 81 21 22 ou envoyez un message. Réponse sous 48 h, sans engagement."
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://jdzootherapeute.fr/" },
        { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://jdzootherapeute.fr/contact" }
      ]
    })} />
  </Fragment>

  <Header slot="header" />

  <PageHero
    h1="Prenons contact — Premier échange gratuit et sans engagement"
    subtitle="Appelez Jennifer directement ou envoyez-lui un message. Elle vous répond sous 48 h pour comprendre votre situation et vous proposer un accompagnement adapté."
    variant="light"
  />

  <!-- Fil d'Ariane -->
  <nav aria-label="Fil d'Ariane" class="bg-white border-b border-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <ol class="flex items-center gap-2 text-xs text-neutral-500">
        <li><a href="/" class="hover:text-primary-600 transition-colors">Accueil</a></li>
        <li aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg></li>
        <li class="text-primary-700 font-medium" aria-current="page">Contact</li>
      </ol>
    </div>
  </nav>

  <!-- Calculateur de tarif avant le formulaire -->
  <TarifCalculator />

  <!-- Formulaire général + coordonnées -->
  <Contact />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
