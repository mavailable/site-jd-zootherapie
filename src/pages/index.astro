---
export const prerender = true;

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import Hero from '@components/sections/Hero.astro';
import SocialProof from '@components/sections/SocialProof.astro';
import PhotoGallery from '@components/sections/PhotoGallery.astro';
import About from '@components/sections/About.astro';
import FAQ from '@components/sections/FAQ.astro';
import CTABanner from '@components/sections/CTABanner.astro';
import StickyMobileCTA from '@components/ui/StickyMobileCTA.astro';
import TarifCalculator from '@components/sections/TarifCalculator.astro';

// ── Section Services aperçu (3 vignettes thématiques, homepage seulement) ────
// Pas les 6 services Keystatic — juste 3 catégories grand public
const servicesApercu = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
    titre: 'Pour les particuliers',
    texte: 'Séances individuelles à domicile pour enfants, adultes et personnes âgées. 60 € / séance, déplacement inclus.',
    href: '/ateliers',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    titre: 'Pour les familles',
    texte: 'Ateliers aidant-aidé ou en famille pour renforcer le lien et partager un moment unique avec les animaux.',
    href: '/ateliers',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    titre: 'Pour les structures',
    texte: 'Interventions en EHPAD, IME, école ou bibliothèque. Tarif sur projet, suivi régulier, co-construction avec vos équipes.',
    href: '/contact',
  },
];
---

<BaseLayout
  title="JD Zoothérapie — Médiation animale en Moselle | Jennifer De Groeve"
  description="Zoothérapeute certifiée en Moselle. Séances à domicile et en structure pour enfants, adultes, seniors. Premier échange gratuit. Verny (57420)."
>
  <!-- Preload hero image pour LCP (responsive) -->
  <link rel="preload" as="image" href="/images/hero-bg.webp"
    imagesrcset="/images/hero-bg-mobile.webp 768w, /images/hero-bg.webp 1920w"
    imagesizes="(max-width: 767px) 100vw, 100vw"
    slot="head" />

  <!-- Schema.org JSON-LD -->
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "JD Zoothérapie",
      "alternateName": "Patt'es Tendres",
      "description": "Jennifer De Groeve, zoothérapeute certifiée en Moselle. Séances de médiation animale à domicile et en structure pour enfants, adultes et personnes âgées.",
      "url": "https://jdzootherapeute.fr",
      "telephone": "+33754812122",
      "email": "degroeve.j@gmail.com",
      "image": "https://jdzootherapeute.fr/images/og-default.webp",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "17 rue Principale",
        "addressLocality": "Vigny",
        "postalCode": "57420",
        "addressRegion": "Grand Est",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 49.0208014,
        "longitude": 6.7659488
      },
      "areaServed": [
        { "@type": "GeoCircle", "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 49.0208014, "longitude": 6.7659488 }, "geoRadius": "15000" },
        { "@type": "City", "name": "Metz" },
        { "@type": "City", "name": "Nancy" }
      ],
      "founder": {
        "@type": "Person",
        "name": "Jennifer De Groeve",
        "jobTitle": "Praticienne certifiée en médiation animale",
        "description": "Aide-soignante diplômée avec plus de 20 ans d'expérience, formée à l'Institut de Formation en Zoothérapie (IFZ).",
        "knowsAbout": ["Zoothérapie", "Médiation animale", "Maladies neurodégénératives", "Accompagnement enfants", "Accompagnement personnes âgées"]
      },
      "priceRange": "60€",
      "currenciesAccepted": "EUR",
      "logo": "https://jdzootherapeute.fr/favicon.svg",
      "memberOf": { "@type": "Organization", "name": "Syndicat Français des Zoothérapeutes" },
      "sameAs": [
        "https://www.facebook.com/profile.php?id=61573108913954",
        "https://www.instagram.com/jenniferzootherapeute",
        "https://www.google.com/maps/place/De+Groeve+Jennifer+zootherapie+-+m%C3%A8diation+animale/@49.0208014,6.7659488,17z"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "bestRating": "5",
        "worstRating": "1",
        "reviewCount": "9" /* ← mettre à jour manuellement */
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "JD Zoothérapie",
      "url": "https://jdzootherapeute.fr",
      "description": "Zoothérapeute certifiée en Moselle. Séances de médiation animale à domicile et en structure.",
      "inLanguage": "fr"
    })} />
  </Fragment>

  <Header slot="header" />

  <!-- 1. Hero -->
  <Hero />

  <!-- 2. Preuve sociale : stats + témoignages -->
  <SocialProof />

  <!-- 3. Aperçu des services — fond primary-50, layout cards 3 colonnes -->
  <section id="services" class="bg-primary-50 py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading font-semibold text-2xl md:text-[2rem] text-primary-900 mb-3">
          Des ateliers pour tous les publics
        </h2>
        <p class="text-neutral-600 max-w-xl mx-auto">
          Que vous soyez particulier, famille ou structure institutionnelle, la médiation animale s'adapte à vos besoins et à votre contexte.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {servicesApercu.map((s) => (
          <a
            href={s.href}
            class="group bg-white border border-neutral-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col"
          >
            <div
              class="inline-flex items-center justify-center w-11 h-11 bg-primary-100 text-primary-600 rounded-lg mb-4 shrink-0 group-hover:bg-primary-200 transition-colors"
              set:html={s.icon}
            />
            <h3 class="font-heading font-semibold text-base text-primary-900 mb-2 group-hover:text-primary-700 transition-colors">{s.titre}</h3>
            <p class="text-neutral-700 text-sm leading-relaxed flex-1">{s.texte}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-primary-600 text-xs font-medium group-hover:gap-2 transition-all">
              En savoir plus
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
            </span>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/ateliers"
          class="inline-flex items-center justify-center gap-2 bg-accent-700 text-white px-7 py-3.5 rounded font-semibold text-base hover:bg-accent-800 transition-colors min-h-[44px]"
        >
          Voir tous les ateliers
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Calculateur de tarif — compact, entre services et galerie -->
  <section class="bg-white py-14 md:py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <TarifCalculator compact={true} />
    </div>
  </section>

  <!-- 5. Galerie photos — vrais moments de séances -->
  <PhotoGallery />

  <!-- 5. À propos (snippet — fond blanc, asymétrique) -->
  <About snippet={true} />

  <!-- 5. FAQ (5 questions sur l'accueil) — fond primary-50 -->
  <FAQ limit={5} showLink={true} />

  <!-- 6. CTA bannière — fond primary-800 -->
  <CTABanner
    title="Prêt à découvrir la médiation animale ?"
    text="Premier échange téléphonique gratuit et sans engagement. Jennifer vous répond sous 48 h."
    ctaText="Appeler Jennifer"
    ctaSecondaryText="Voir les ateliers"
    ctaSecondaryHref="/ateliers"
  />

  <Footer slot="footer" />
  <StickyMobileCTA />
</BaseLayout>
