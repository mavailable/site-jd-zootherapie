};

// Stats
const convertis = personas.filter(p => p.issue === 'convertit').length;
const hesitent = personas.filter(p => p.issue === 'hesite').length;
const quittent = personas.filter(p => p.issue === 'quitte').length;
const avgExp = (personas.reduce((s, p) => s + p.scores.exp, 0) / 20).toFixed(1);
const avgConf = (personas.reduce((s, p) => s + p.scores.conf, 0) / 20).toFixed(1);
const avgClarte = (personas.reduce((s, p) => s + p.scores.clarte, 0) / 20).toFixed(1);

const pageMap: Record<string, string> = {
  'Accueil': '/', 'Zootherapie': '/zootherapie', 'Ateliers': '/ateliers',
  'A propos': '/a-propos', 'Tarifs': '/tarifs', 'Temoignages': '/temoignages',
