---

import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';

// ── Donnees personas ──
const personas = [
  { id: 1, nom: 'Francoise', age: 68, emoji: '👵', situation: 'Retraitee, vit seule a Verny', canal: 'Google', contexte: 'Isolee depuis le deces de son mari. Sa fille lui a parle de zootherapie.', parcours: ['Accueil', 'Zootherapie', 'Ateliers', 'Tarifs', 'Temoignages'], issue: 'hesite', questionCle: 'La zootherapie, c\'est pour quelqu\'un comme moi ?', frein: 'Pas de temoignage de senior isole a domicile' },
  { id: 2, nom: 'Nadia', age: 42, emoji: '👩‍⚕️', situation: 'Cadre de sante EHPAD', canal: 'Google Maps', contexte: 'Cherche un prestataire pour le projet d\'etablissement de son EHPAD.', parcours: ['Accueil', 'Ateliers', 'A propos', 'Tarifs', 'Contact'], issue: 'convertit', questionCle: 'Jennifer peut-elle s\'integrer a notre projet ?', frein: 'Pas de page dediee aux structures' },
  { id: 3, nom: 'Thomas', age: 35, emoji: '👨‍💻', situation: 'Papa d\'un enfant TDAH, Metz', canal: 'ChatGPT', contexte: 'Le pedopsychiatre a suggere des approches complementaires pour son fils.', parcours: ['Accueil', 'Zootherapie', 'Ateliers', 'FAQ', 'Tarifs'], issue: 'hesite', questionCle: 'Ca marche vraiment pour les enfants TDAH ?', frein: 'Aucune preuve ou temoignage TDAH' },
  { id: 4, nom: 'Celine', age: 51, emoji: '🤱', situation: 'Aidante de sa mere (Parkinson)', canal: 'Facebook', contexte: 'Epuisee, touchee par une photo de Tap-Tap sur Facebook.', parcours: ['Accueil', 'Ateliers', 'Tarifs'], issue: 'hesite', questionCle: 'Ca peut aider ma mere ET me soulager ?', frein: 'Budget serre, formulaire trop formel' },
  { id: 5, nom: 'Mehdi', age: 29, emoji: '👨‍🏫', situation: 'Educateur specialise, Nancy', canal: 'Google', contexte: 'Cherche une formation, pas un prestataire.', parcours: ['Accueil', 'Zootherapie'], issue: 'quitte', questionCle: 'Proposez-vous des formations ?', frein: 'Besoin incompatible' },
  { id: 6, nom: 'Christine', age: 74, emoji: '👵', situation: 'Benevole bibliotheque Marly', canal: 'Bouche-a-oreille', contexte: 'A deja vu Jennifer. Veut offrir des seances a son petit-fils.', parcours: ['Accueil', 'Ateliers', 'Tarifs', 'Contact'], issue: 'convertit', questionCle: 'Comment reserver pour mon petit-fils ?', frein: '' },
  { id: 7, nom: 'Aurelie', age: 38, emoji: '👩', situation: 'Maman solo, 2 filles, Augny', canal: 'Instagram', contexte: 'Sa fille a des difficultes emotionnelles depuis la separation.', parcours: ['Accueil', 'Ateliers', 'Tarifs', 'FAQ', 'Temoignages'], issue: 'hesite', questionCle: 'La zootherapie peut aider ma fille ?', frein: 'Pas d\'info remboursement ni frequence' },
  { id: 8, nom: 'Patrick', age: 62, emoji: '👨‍💼', situation: 'Directeur foyer medicalise', canal: 'Google', contexte: 'Veut enrichir le programme d\'activites de son foyer.', parcours: ['Accueil', 'A propos', 'Ateliers', 'Tarifs', 'Contact'], issue: 'hesite', questionCle: 'Experience avec le handicap lourd ?', frein: 'Pas de page structures, tarif groupes vague' },
  { id: 9, nom: 'Lea', age: 26, emoji: '👩‍🎓', situation: 'Etudiante en psychologie, Nancy', canal: 'Perplexity', contexte: 'Cherche un professionnel a interviewer pour son memoire.', parcours: ['Accueil', 'A propos', 'FAQ', 'Contact'], issue: 'convertit', questionCle: 'Quelle est votre formation ?', frein: '' },
  { id: 10, nom: 'Jean-Marc', age: 55, emoji: '🩺', situation: 'Medecin generaliste, Verny', canal: 'Google Maps', contexte: 'Verifie le profil de Jennifer avant de la recommander.', parcours: ['Accueil', 'A propos', 'Zootherapie', 'FAQ'], issue: 'hesite', questionCle: 'Assez qualifiee pour que je recommande ?', frein: 'Pas de disclaimer medical' },
  { id: 11, nom: 'Sandrine', age: 44, emoji: '👩‍🏫', situation: 'Directrice d\'ecole primaire', canal: 'Email', contexte: 'Cherche un intervenant pour la Semaine du bien-etre.', parcours: ['Accueil', 'Ateliers', 'Tarifs', 'Contact'], issue: 'hesite', questionCle: 'Intervention en ecole ?', frein: 'Pas de contenu scolaire specifique' },
  { id: 12, nom: 'Antoine', age: 31, emoji: '💪', situation: 'Kine liberal, Metz', canal: 'Google', contexte: 'Curieux mais sceptique. Cherche des preuves scientifiques.', parcours: ['Accueil', 'Zootherapie'], issue: 'quitte', questionCle: 'Quelles preuves scientifiques ?', frein: 'Zero reference scientifique' },
  { id: 13, nom: 'Monique', age: 71, emoji: '👵', situation: 'Ex-infirmiere, Marieulles', canal: 'Bouche-a-oreille', contexte: 'Sa fille (sclerose en plaques) vit un episode difficile.', parcours: ['Accueil', 'FAQ', 'Ateliers', 'Contact'], issue: 'convertit', questionCle: 'Ca aide pour la sclerose en plaques ?', frein: 'La SEP n\'est pas mentionnee' },
  { id: 14, nom: 'Elodie', age: 33, emoji: '👩', situation: 'Maman d\'un enfant autiste, Fey', canal: 'Facebook', contexte: 'Recommandee sur un groupe Facebook de parents.', parcours: ['Accueil', 'Zootherapie', 'Ateliers', 'A propos', 'FAQ', 'Contact'], issue: 'convertit', questionCle: 'Seance avec un enfant autiste ?', frein: 'Pas de temoignage parent TSA' },
  { id: 15, nom: 'Karim', age: 47, emoji: '👷', situation: 'Chef de chantier BTP', canal: 'Google', contexte: 'Cherche un eleveur de finnois de Laponie. Erreur.', parcours: ['Accueil', 'A propos'], issue: 'quitte', questionCle: 'Ou trouver un finnois de Laponie ?', frein: 'Visiteur hors cible' },
  { id: 16, nom: 'Isabelle', age: 58, emoji: '🧠', situation: 'Psychologue clinicienne, Metz', canal: 'Google Maps', contexte: 'Patiente en impasse therapeutique. Cherche un relais.', parcours: ['Accueil', 'A propos', 'Ateliers', 'Contact'], issue: 'convertit', questionCle: 'Peut-on travailler ensemble ?', frein: 'Pas de mention collaboration pro' },
  { id: 17, nom: 'Lucas', age: 22, emoji: '👨‍🎓', situation: 'Etudiant BTS, Metz', canal: 'Claude (IA)', contexte: 'Cherche un exemple concret pour son expose.', parcours: ['Accueil', 'Zootherapie', 'A propos', 'FAQ'], issue: 'quitte', questionCle: 'Integration dans le parcours de soin ?', frein: 'Visite documentaire uniquement' },
  { id: 18, nom: 'Marie-Therese', age: 81, emoji: '👵', situation: 'Alzheimer leger, Verny', canal: 'Bouche-a-oreille', contexte: 'Son fils lui a envoye le lien sur conseil du medecin.', parcours: ['Accueil', 'A propos'], issue: 'convertit', questionCle: 'Les animaux sont gentils ?', frein: 'Navigation trop complexe — son fils appelle' },
  { id: 19, nom: 'Stephanie', age: 40, emoji: '👩‍⚕️', situation: 'Infirmiere EHPAD, Marly', canal: 'QR code flyer', contexte: 'Se demande si c\'est aussi pour elle, pas ses patients.', parcours: ['Accueil', 'Ateliers', 'Zootherapie', 'Tarifs'], issue: 'hesite', questionCle: 'Je peux venir juste pour moi ?', frein: 'Le site ne dit jamais "c\'est aussi pour vous"' },
  { id: 20, nom: 'David', age: 46, emoji: '👔', situation: 'Responsable qualite entreprise', canal: 'LinkedIn', contexte: 'Cherche du bien-etre pour la Semaine QVT.', parcours: ['Accueil', 'Ateliers', 'Tarifs'], issue: 'quitte', questionCle: 'Interventions en entreprise ?', frein: 'Aucune offre entreprise' },
];

const convertis = personas.filter(p => p.issue === 'convertit');
const hesitent = personas.filter(p => p.issue === 'hesite');
const quittent = personas.filter(p => p.issue === 'quitte');

const issueStyle: Record<string, { bg: string; text: string; label: string; dot: string }> = {
  convertit: { bg: 'bg-green-50', text: 'text-green-700', label: 'Vous contacte', dot: 'bg-green-500' },
  hesite: { bg: 'bg-amber-50', text: 'text-amber-700', label: 'Hesite', dot: 'bg-amber-400' },
  quitte: { bg: 'bg-red-50', text: 'text-red-600', label: 'Repart', dot: 'bg-red-400' },
};
---

<BaseLayout
  title="Personas — Qui visite votre site ?"
  description="Comprendre vos visiteurs pour ameliorer votre site."
  noindex={true}
>
  <Header slot="header" />

  <!-- ─── Back link ─── -->
  <div class="bg-white border-b border-neutral-100">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <a href="/aide-601302f4" class="inline-flex items-center gap-1.5 text-xs text-neutral-500 hover:text-primary-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour
      </a>
    </div>
  </div>

  <!-- ─── Hero compact ─── -->
  <section class="bg-primary-800 py-8 md:py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-heading text-2xl md:text-3xl font-bold text-white mb-2">Qui pourrait visiter votre site ?</h1>
      <p class="text-primary-200 text-sm max-w-lg mx-auto">20 profils fictifs generes par intelligence artificielle pour simuler des visites realistes et identifier ce qui fonctionne — et ce qu'on peut ameliorer.</p>
    </div>
  </section>

  <!-- ─── Tab bar ─── -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm">
      <button data-tab="0" class="tab-btn px-5 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-primary-700 bg-primary-50">
        Visiteurs
        <span class="ml-1 text-xs text-primary-400">20</span>
      </button>
      <button data-tab="1" class="tab-btn px-5 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Ameliorations
        <span class="ml-1 text-xs text-neutral-400">13</span>
      </button>
    </div>
  </nav>

  <!-- ─── Swipeable panels ─── -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

    <!-- ══════ PANEL 1 : VISITEURS ══════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- Stats row -->
      <div class="bg-white py-6 border-b border-neutral-100">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-center gap-8 md:gap-14">
          <div class="text-center">
            <div class="text-3xl font-bold text-green-600">{convertis.length}</div>
            <div class="text-xs text-neutral-500 mt-1">vous contactent</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-amber-500">{hesitent.length}</div>
            <div class="text-xs text-neutral-500 mt-1">hesitent</div>
          </div>
          <div class="text-center">
            <div class="text-3xl font-bold text-red-400">{quittent.length}</div>
            <div class="text-xs text-neutral-500 mt-1">repartent</div>
          </div>
        </div>
      </div>

      <!-- Ceux qui convertissent -->
      <div class="bg-white py-8">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="w-2.5 h-2.5 rounded-full bg-green-500 shrink-0"></span>
            <h2 class="font-heading text-lg font-bold text-neutral-900">Ceux qui vous contactent</h2>
            <span class="text-xs text-neutral-400 ml-1">{convertis.length} visiteurs</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            {convertis.map((p) => (
              <article class="border border-green-200 bg-green-50/40 rounded-xl p-4 flex gap-3">
                <div class="text-xl shrink-0 mt-0.5">{p.emoji}</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5">
                    <h3 class="font-semibold text-neutral-900 text-sm">{p.nom}, {p.age} ans</h3>
                    <span class="text-[11px] text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded">{p.canal}</span>
                  </div>
                  <p class="text-xs text-neutral-500 mb-2">{p.situation}</p>
                  <p class="text-xs text-neutral-600 mb-2.5">{p.contexte}</p>
                  <div class="flex flex-wrap items-center gap-1">
                    {p.parcours.map((page, i) => (
                      <>
                        <span class="text-[10px] text-primary-700 bg-white border border-primary-100 px-1.5 py-0.5 rounded">{page}</span>
                        {i < p.parcours.length - 1 && <span class="text-neutral-300 text-[10px]">›</span>}
                      </>
                    ))}
                    <span class="text-[10px] bg-green-600 text-white px-1.5 py-0.5 rounded font-medium ml-0.5">Appelle</span>
                  </div>
                  {p.frein && (
                    <p class="text-[11px] text-amber-700 mt-2 leading-snug">A noter : {p.frein}</p>
                  )}
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <!-- Ceux qui hesitent -->
      <div class="bg-neutral-50 py-8">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-2.5 mb-1">
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400 shrink-0"></span>
            <h2 class="font-heading text-lg font-bold text-neutral-900">Ceux qui hesitent</h2>
            <span class="text-xs text-neutral-400 ml-1">{hesitent.length} visiteurs</span>
          </div>
          <p class="text-xs text-neutral-500 mb-5 ml-5">Interesses mais pas convaincus — c'est la ou on peut progresser le plus.</p>
          <div class="space-y-3">
            {hesitent.map((p) => (
              <article class="border border-amber-200 bg-white rounded-xl p-4 flex gap-3">
                <div class="text-xl shrink-0 mt-0.5">{p.emoji}</div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                    <h3 class="font-semibold text-neutral-900 text-sm">{p.nom}, {p.age} ans — {p.situation}</h3>
                    <span class="text-[11px] text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded">{p.canal}</span>
                  </div>
                  <p class="text-xs text-neutral-600 mb-3">{p.contexte}</p>
                  <div class="flex flex-wrap items-center gap-1 mb-3">
                    {p.parcours.map((page, i) => (
                      <>
                        <span class="text-[10px] text-primary-700 bg-neutral-50 border border-neutral-200 px-1.5 py-0.5 rounded">{page}</span>
                        {i < p.parcours.length - 1 && <span class="text-neutral-300 text-[10px]">›</span>}
                      </>
                    ))}
                    <span class="text-[10px] bg-amber-100 text-amber-700 px-1.5 py-0.5 rounded font-medium ml-0.5">Hesite…</span>
                  </div>
                  <div class="bg-amber-50 rounded-lg px-3 py-2 border border-amber-100">
                    <p class="text-xs text-neutral-700 italic mb-1">"{p.questionCle}"</p>
                    <p class="text-xs text-amber-700 font-medium">{p.frein}</p>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>

      <!-- Ceux qui partent -->
      <div class="bg-white py-8">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center gap-2.5 mb-1">
            <span class="w-2.5 h-2.5 rounded-full bg-red-400 shrink-0"></span>
            <h2 class="font-heading text-lg font-bold text-neutral-900">Ceux qui repartent</h2>
            <span class="text-xs text-neutral-400 ml-1">{quittent.length} visiteurs</span>
          </div>
          <p class="text-xs text-neutral-500 mb-5 ml-5">Ils ne cherchaient pas ce que vous proposez. C'est normal.</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3">
            {quittent.map((p) => (
              <article class="border border-neutral-200 bg-neutral-50/50 rounded-xl p-3.5">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-lg">{p.emoji}</span>
                  <div>
                    <h3 class="font-semibold text-neutral-800 text-xs">{p.nom}, {p.age} ans</h3>
                    <span class="text-[11px] text-blue-600">{p.canal}</span>
                  </div>
                </div>
                <p class="text-xs text-neutral-500 mb-1.5">{p.contexte}</p>
                <p class="text-[11px] text-red-500 italic">{p.frein}</p>
              </article>
            ))}
          </div>
        </div>
      </div>

    </section>

    <!-- ══════ PANEL 2 : AMELIORATIONS ══════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0 py-10 md:py-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

        <h2 class="font-heading text-2xl font-bold text-neutral-900 mb-1">Ameliorations proposees</h2>
        <p class="text-sm text-neutral-500 mb-8">Actions concretes pour transformer les hesitants en clients, classees par importance.</p>

        <!-- ── Le plus important ── -->
        <div class="mb-10">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0"></span>
            <h3 class="font-bold text-neutral-900 text-sm uppercase tracking-wider">Le plus important</h3>
          </div>
          <div class="space-y-4">

            <div class="bg-white border-2 border-red-200 rounded-xl p-5 shadow-sm">
              <h4 class="font-semibold text-neutral-900 mb-2">Collecter plus de temoignages</h4>
              <p class="text-sm text-neutral-600 mb-3">8 visiteurs sur 20 cherchent un temoignage qui ressemble a leur situation. Il manque :</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-4">
                <div class="flex items-center gap-2 bg-red-50 rounded-lg px-3 py-2">
                  <span class="text-sm">👨‍👦</span>
                  <span class="text-xs text-neutral-700">Parent d'enfant TDAH ou autiste</span>
                </div>
                <div class="flex items-center gap-2 bg-red-50 rounded-lg px-3 py-2">
                  <span class="text-sm">🤱</span>
                  <span class="text-xs text-neutral-700">Aidant familial epuise</span>
                </div>
                <div class="flex items-center gap-2 bg-red-50 rounded-lg px-3 py-2">
                  <span class="text-sm">👨‍💼</span>
                  <span class="text-xs text-neutral-700">Directeur d'EHPAD ou de foyer</span>
                </div>
                <div class="flex items-center gap-2 bg-red-50 rounded-lg px-3 py-2">
                  <span class="text-sm">👵</span>
                  <span class="text-xs text-neutral-700">Personne agee suivie a domicile</span>
                </div>
              </div>
              <div class="bg-primary-50 rounded-lg px-3 py-2.5 flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                <p class="text-xs text-primary-800">Jennifer peut demander un avis apres chaque seance — meme 2-3 phrases suffisent. Le lien d'avis Google est sur votre <a href="/aide-601302f4" class="underline">page d'aide</a>.</p>
              </div>
            </div>

            <div class="bg-white border-2 border-red-200 rounded-xl p-5 shadow-sm">
              <h4 class="font-semibold text-neutral-900 mb-2">Ajouter les infos budget et frequence</h4>
              <p class="text-sm text-neutral-600 mb-3">6 visiteurs ne savent pas combien de seances prevoir ni si c'est rembourse.</p>
              <div class="space-y-2 mb-4">
                <div class="flex items-start gap-2 text-sm text-neutral-700">
                  <span class="text-primary-500 mt-0.5 shrink-0">+</span>
                  <span>"En moyenne 6 a 8 seances, toutes les 2 semaines"</span>
                </div>
                <div class="flex items-start gap-2 text-sm text-neutral-700">
                  <span class="text-primary-500 mt-0.5 shrink-0">+</span>
                  <span>"Renseignez-vous aupres de votre mutuelle" (certaines remboursent)</span>
                </div>
                <div class="flex items-start gap-2 text-sm text-neutral-700">
                  <span class="text-primary-500 mt-0.5 shrink-0">+</span>
                  <span>Ajouter une FAQ : "Est-ce rembourse ?"</span>
                </div>
              </div>
              <div class="bg-primary-50 rounded-lg px-3 py-2.5 flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                <p class="text-xs text-primary-800">A ajouter sur la page Tarifs et dans la FAQ.</p>
              </div>
            </div>

            <div class="bg-white border-2 border-red-200 rounded-xl p-5 shadow-sm">
              <h4 class="font-semibold text-neutral-900 mb-2">Mieux parler aux structures</h4>
              <p class="text-sm text-neutral-600 mb-3">5 visiteurs (directeurs EHPAD, ecole, medecins) cherchent un dossier a presenter. On peut ajouter :</p>
              <div class="space-y-2 mb-4">
                <div class="flex items-start gap-2 text-sm text-neutral-700">
                  <span class="text-primary-500 mt-0.5 shrink-0">+</span>
                  <span>Un encart "Vous etes une structure ?" sur la page Ateliers</span>
                </div>
                <div class="flex items-start gap-2 text-sm text-neutral-700">
                  <span class="text-primary-500 mt-0.5 shrink-0">+</span>
                  <span>Mention de l'assurance et du suivi veterinaire</span>
                </div>
                <div class="flex items-start gap-2 text-sm text-neutral-700">
                  <span class="text-primary-500 mt-0.5 shrink-0">+</span>
                  <span>Une plaquette PDF a telecharger</span>
                </div>
              </div>
              <div class="bg-primary-50 rounded-lg px-3 py-2.5 flex items-start gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                <p class="text-xs text-primary-800">Marc peut creer l'encart et la plaquette.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Utile aussi ── -->
        <div class="mb-10">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="w-2.5 h-2.5 rounded-full bg-amber-400 shrink-0"></span>
