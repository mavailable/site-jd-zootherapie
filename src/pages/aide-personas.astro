---

<BaseLayout
  title="Personas — Qui visite votre site ?"
  description="20 profils de visiteurs types, leur parcours et les recommandations pour ameliorer votre site."
  noindex={true}
>
  <Header slot="header" />

  <!-- ─── Back link ─── -->
  <div class="bg-white border-b border-neutral-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5">
      <a href="/aide-601302f4" class="inline-flex items-center gap-1.5 text-xs text-neutral-500 hover:text-primary-600 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        Retour a l'espace administration
      </a>
    </div>
  </div>

  <!-- ─── Hero ─── -->
  <section class="bg-primary-800 py-10 md:py-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-heading text-2xl md:text-3xl font-bold text-white mb-2">Qui visite votre site ?</h1>
      <p class="text-primary-200 text-sm md:text-base max-w-2xl">20 profils de visiteurs simules pour comprendre comment les gens decouvrent et utilisent votre site — et ce qu'on peut ameliorer.</p>
    </div>
  </section>

  <!-- ─── Stats globales ─── -->
  <section class="bg-white py-8 border-b border-neutral-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-4">
        <div class="text-center">
          <div class="text-2xl font-bold text-green-600">{convertis}</div>
          <div class="text-xs text-neutral-500 mt-0.5">Convertissent</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-amber-500">{hesitent}</div>
          <div class="text-xs text-neutral-500 mt-0.5">Hesitent</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-red-500">{quittent}</div>
          <div class="text-xs text-neutral-500 mt-0.5">Quittent</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-primary-600">{avgExp}<span class="text-sm font-normal text-neutral-400">/10</span></div>
          <div class="text-xs text-neutral-500 mt-0.5">Experience</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-primary-600">{avgConf}<span class="text-sm font-normal text-neutral-400">/10</span></div>
          <div class="text-xs text-neutral-500 mt-0.5">Confiance</div>
        </div>
        <div class="text-center">
          <div class="text-2xl font-bold text-primary-600">{avgClarte}<span class="text-sm font-normal text-neutral-400">/10</span></div>
          <div class="text-xs text-neutral-500 mt-0.5">Clarte</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Filtres (JS) ─── -->
  <section class="bg-neutral-50 border-b border-neutral-100 py-3 sticky top-16 md:top-20 z-30">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center gap-2">
      <span class="text-xs text-neutral-400 font-medium mr-1">Filtrer :</span>
      <button data-filter="all" class="filter-btn text-xs px-3 py-1 rounded-full font-medium bg-primary-600 text-white">Tous (20)</button>
      <button data-filter="convertit" class="filter-btn text-xs px-3 py-1 rounded-full font-medium bg-white text-neutral-600 border border-neutral-200 hover:border-green-300">Convertit ({convertis})</button>
      <button data-filter="hesite" class="filter-btn text-xs px-3 py-1 rounded-full font-medium bg-white text-neutral-600 border border-neutral-200 hover:border-amber-300">Hesite ({hesitent})</button>
      <button data-filter="quitte" class="filter-btn text-xs px-3 py-1 rounded-full font-medium bg-white text-neutral-600 border border-neutral-200 hover:border-red-300">Quitte ({quittent})</button>
    </div>
  </section>

  <!-- ─── Grille des personas ─── -->
  <section class="bg-neutral-50 py-8 md:py-10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="persona-grid">
        {personas.map((p) => {
          const issue = issueColors[p.issue];
          const rep = reponseLabels[p.reponse];
          return (
            <article
              class="persona-card bg-white border border-neutral-200 rounded-xl overflow-hidden hover:shadow-md transition-shadow"
              data-issue={p.issue}
            >
              {/* Header card */}
              <div class="flex items-center justify-between px-5 py-3.5 border-b border-neutral-100">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center font-bold text-sm shrink-0">
                    {p.id}
                  </div>
                  <div>
                    <h3 class="font-semibold text-neutral-900 text-sm">{p.nom}, {p.age} ans</h3>
                    <p class="text-xs text-neutral-500">{p.situation}</p>
                  </div>
                </div>
                <span class={`text-[11px] font-semibold px-2.5 py-1 rounded-full ${issue.bg} ${issue.text}`}>{issue.label}</span>
              </div>

              {/* Body */}
              <div class="px-5 py-4 space-y-3.5">
                {/* Meta : canal, device, maturite */}
                <div class="flex flex-wrap gap-1.5">
                  <span class="text-[11px] bg-blue-50 text-blue-700 px-2 py-0.5 rounded font-medium">{p.canal}</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">{p.device}</span>
                  <span class="text-[11px] bg-neutral-100 text-neutral-600 px-2 py-0.5 rounded">{p.maturite}</span>
                </div>

                {/* Contexte */}
                <p class="text-xs text-neutral-600 leading-relaxed">{p.contexte}</p>

                {/* Parcours */}
                <div>
                  <div class="text-[10px] text-neutral-400 font-semibold uppercase tracking-wider mb-1.5">Parcours</div>
                  <div class="flex flex-wrap items-center gap-1">
                    {p.parcours.map((page, i) => (
                      <>
                        <a href={pageMap[page] || '#'} class="text-[11px] bg-primary-50 text-primary-700 px-2 py-0.5 rounded hover:bg-primary-100 transition-colors">{page}</a>
                        {i < p.parcours.length - 1 && (
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-neutral-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                        )}
                      </>
                    ))}
                  </div>
                </div>

                {/* Question cle */}
                <div class="bg-neutral-50 rounded-lg p-3">
                  <div class="flex items-start justify-between gap-2">
                    <p class="text-xs text-neutral-700 italic flex-1">"{p.questionCle}"</p>
                    <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full shrink-0 ${rep.bg} ${rep.text}`}>{rep.label}</span>
                  </div>
                </div>

                {/* Friction */}
                <div class="flex items-start gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-amber-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                  <p class="text-xs text-neutral-600">{p.frictionPrincipale}</p>
                </div>

                {/* Scores mini */}
                <div class="flex gap-4 pt-1">
                  <div class="flex items-center gap-1.5">
                    <div class="w-16 h-1.5 bg-neutral-100 rounded-full overflow-hidden">
                      <div class="h-full bg-primary-500 rounded-full" style={`width: ${p.scores.exp * 10}%`}></div>
                    </div>
                    <span class="text-[10px] text-neutral-400">Exp {p.scores.exp}</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <div class="w-16 h-1.5 bg-neutral-100 rounded-full overflow-hidden">
                      <div class="h-full bg-primary-500 rounded-full" style={`width: ${p.scores.conf * 10}%`}></div>
                    </div>
                    <span class="text-[10px] text-neutral-400">Conf {p.scores.conf}</span>
                  </div>
                  <div class="flex items-center gap-1.5">
                    <div class="w-16 h-1.5 bg-neutral-100 rounded-full overflow-hidden">
                      <div class="h-full bg-primary-500 rounded-full" style={`width: ${p.scores.clarte * 10}%`}></div>
                    </div>
                    <span class="text-[10px] text-neutral-400">Clarte {p.scores.clarte}</span>
                  </div>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ─── Recommandations ─── -->
  <section class="bg-white py-10 md:py-14" id="recommandations">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-xl md:text-2xl font-bold text-neutral-900 mb-2">Recommandations</h2>
      <p class="text-sm text-neutral-500 mb-8">Actions concretes pour ameliorer l'experience des visiteurs, classees par impact.</p>

      <div class="space-y-6">
        {recommendations.map((group) => {
          const style = prioriteStyles[group.priorite];
          return (
            <div>
              <div class="flex items-center gap-2 mb-3">
                <span class={`text-[11px] font-semibold px-2.5 py-1 rounded-full ${style.badge} ${style.badgeText}`}>{style.label}</span>
                <span class="text-xs text-neutral-400">{group.items.length} actions</span>
              </div>
              <div class="space-y-3">
                {group.items.map((item) => (
                  <div class={`${style.bg} border ${style.border} rounded-xl p-4`}>
                    <div class="flex items-start justify-between gap-3 mb-2">
                      <h3 class="font-semibold text-neutral-900 text-sm">{item.titre}</h3>
                      <div class="flex items-center gap-1 shrink-0">
                        {item.personas.map((pid) => (
                          <span class="w-5 h-5 rounded-full bg-white border border-neutral-200 text-[10px] font-medium text-neutral-600 flex items-center justify-center">{pid}</span>
                        ))}
                      </div>
                    </div>
                    <p class="text-xs text-neutral-600 mb-2">{item.detail}</p>
                    <div class="flex items-center gap-1.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-primary-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                      <span class="text-xs text-primary-700 font-medium">{item.action}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ─── Contact webmaster ─── -->
  <div class="text-center py-6 border-t border-neutral-100 text-xs text-neutral-400">
    Questions ? <a href="mailto:marc@muller.im" class="text-primary-600 font-medium hover:text-primary-700 transition-colors">marc@muller.im</a>
  </div>

  <Footer slot="footer" />

  <!-- ─── Filter script ─── -->
  <script is:inline>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.persona-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;

        filterBtns.forEach(b => {
          b.classList.remove('bg-primary-600', 'text-white');
          b.classList.add('bg-white', 'text-neutral-600', 'border', 'border-neutral-200');
        });
        btn.classList.remove('bg-white', 'text-neutral-600', 'border', 'border-neutral-200');
        btn.classList.add('bg-primary-600', 'text-white');

        cards.forEach(card => {
          if (filter === 'all' || card.dataset.issue === filter) {
            card.style.display = '';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
  </script>
</BaseLayout>
