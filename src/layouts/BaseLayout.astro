---
import '@styles/global.css';
import { getSiteInfo } from '@data/content';
import { siteUrl, ads } from '@data/business';
import { getPageSeo, getSeoGlobal } from '../data/seo';
import ConsentBanner from '@components/layout/ConsentBanner.astro';

const siteInfo = await getSiteInfo();

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noindex?: boolean;
  /** 'website' (défaut) ou 'article' pour les articles de blog */
  ogType?: 'website' | 'article';
  /** Date de publication ISO (pour og:type article) */
  articleDate?: string;
}

const {
  title = siteInfo.seo.defaultTitle,
  description = siteInfo.seo.defaultDescription,
  ogImage = siteInfo.seo.ogImage,
  canonicalUrl = Astro.url.href,
  noindex = false,
  ogType = 'website',
  articleDate,
} = Astro.props;

// C2 — Resolution SEO : seo.json gagne sur les props (pour que les edits
// client via /admin#/seo soient visibles). Les props (deja resolus par la
// destructure avec fallback sur siteInfo.seo.defaults) restent en fallback
// pour les pages dynamiques (blog/[slug]) pas encore dans seo.json.
// NOTE jd-zoo : pas de buildTitle — les titres n'ont pas de pattern uniforme
// (home = "JD Zoothérapie — Médiation animale...", pages = "Page — JD Zoothérapie [| subtitle]"),
// le seo.json contient donc les titres complets.
const routePath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const pageSeo = getPageSeo(routePath);
const seoGlobal = getSeoGlobal();

const resolvedTitle = pageSeo?.title ?? title;
const resolvedDescription = pageSeo?.description ?? description;
const resolvedOgImage = pageSeo?.ogImage || ogImage || seoGlobal?.defaultOgImage || '';
const resolvedNoindex = pageSeo?.noindex ?? noindex;

const fullOgImage = resolvedOgImage.startsWith('http') ? resolvedOgImage : `${siteUrl}${resolvedOgImage}`;
const ogLocale = `${siteInfo.lang}_${siteInfo.address.country.toUpperCase()}`;
const ogImageType = fullOgImage.endsWith('.png') ? 'image/png' : fullOgImage.endsWith('.webp') ? 'image/webp' : 'image/jpeg';
---

<!DOCTYPE html>
<html lang={siteInfo.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="format-detection" content="telephone=no" />
  <title>{resolvedTitle}</title>
  <meta name="description" content={resolvedDescription} />
  <link rel="canonical" href={canonicalUrl} />
  {resolvedNoindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Favicon & PWA -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#2D4B4E" />

  <!-- Open Graph -->
  <meta property="og:title" content={resolvedTitle} />
  <meta property="og:description" content={resolvedDescription} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content={ogType} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:site_name" content={siteInfo.name} />
  {ogType === 'article' && articleDate && (
    <meta property="article:published_time" content={articleDate} />
  )}
  {ogType === 'article' && (
    <meta property="article:author" content="Jennifer De Groeve" />
  )}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={resolvedTitle} />
  <meta name="twitter:description" content={resolvedDescription} />
  <meta name="twitter:image" content={fullOgImage} />
  <meta name="twitter:image:alt" content={resolvedTitle} />

  <!-- Polices critiques (above-the-fold) — les autres se chargent via font-display: swap -->
  <link rel="preload" href="/fonts/lora-v37-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-sans-v17-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-sans-v17-latin-600.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Schema.org JSON-LD -->
  <slot name="schema" />

  <!-- Head additionnel -->
  <slot name="head" />

  <style>
    /* @font-face declarations — Lora */
    @font-face {
      font-family: 'Lora';
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url('/fonts/lora-v37-latin-600.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Lora';
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url('/fonts/lora-v37-latin-700.woff2') format('woff2');
    }
    /* @font-face declarations — DM Sans */
    @font-face {
      font-family: 'DM Sans';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/fonts/dm-sans-v17-latin-regular.woff2') format('woff2');
    }
    @font-face {
      font-family: 'DM Sans';
      font-style: normal;
      font-weight: 500;
      font-display: swap;
      src: url('/fonts/dm-sans-v17-latin-500.woff2') format('woff2');
    }
    @font-face {
      font-family: 'DM Sans';
      font-style: normal;
      font-weight: 600;
      font-display: swap;
      src: url('/fonts/dm-sans-v17-latin-600.woff2') format('woff2');
    }
  </style>
</head>
<body class="bg-neutral-50 text-neutral-800 font-body antialiased">
  <!-- Skip-to-content : accessibilité WCAG 2.1 AA -->
  <a href="#main-content"
     class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent-700 focus:text-white focus:px-4 focus:py-2 focus:rounded">
    Aller au contenu principal
  </a>

  <!-- Header -->
  <slot name="header" />

  <!-- Contenu principal -->
  <main id="main-content">
    <slot />
  </main>

  <!-- Footer -->
  <slot name="footer" />

  <!-- Umami Analytics — sans cookies, RGPD-exempt (pas de bannière requise) -->
  <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="96fd46e0-47fa-4c79-abda-447fa79bd0f4" crossorigin="anonymous"></script>

  <!-- Tracking conversions : téléphone, email, CTA, formulaire -->
  <script defer src="/js/analytics.js"></script>

  {ads.enabled && ads.conversionId && (
    <>
      {/* Consent Mode v2 — init en "denied" AVANT le gtag (requis Google) */}
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'granted',
          wait_for_update: 500,
        });
      </script>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ads.conversionId}`}></script>
      <script is:inline define:vars={{ conversionId: ads.conversionId, adsConversionId: ads.adsConversionId }}>
        gtag('js', new Date());
        gtag('config', conversionId);
        if (adsConversionId) gtag('config', adsConversionId);
      </script>
      <ConsentBanner />
    </>
  )}

  <!-- CMS inline editor — charge uniquement si session active -->
  <script is:inline>
    if (document.cookie.includes('cms_logged_in')) {
      const s = document.createElement('script');
      s.src = '/cms-edit.js';
      s.defer = true;
      document.body.appendChild(s);
    }
  </script>
</body>
</html>
