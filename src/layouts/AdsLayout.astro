---
/**
 * AdsLayout.astro
 *
 * Layout minimaliste pour les landing pages Google Ads (/lp/*).
 * Objectif : 1 seule intention, friction minimale, conversion maximale.
 *
 * Différences vs BaseLayout :
 * - Header minimal (logo + tel, pas de nav)
 * - Footer minimal (mentions légales uniquement)
 * - noindex + pas de sitemap
 * - Schema.org WebPage (pas LocalBusiness, conflits avec home)
 * - Inclut Umami + gtag Ads + ConsentBanner si ads.enabled
 */
import '@styles/global.css';
import { getSiteInfo } from '@data/content';
import { siteUrl, ads, schemaData, business } from '@data/business';
import ConsentBanner from '@components/layout/ConsentBanner.astro';

const siteInfo = await getSiteInfo();

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  indexable?: boolean;
  heroImage?: string;
  serviceSchema?: {
    name: string;
    description: string;
    serviceType: string;
    areaServed?: string[];
  };
}

const { title, description, ogImage, indexable = false, heroImage, serviceSchema } = Astro.props;
const fullOgImage = (ogImage || siteInfo.seo.ogImage).startsWith('http')
  ? (ogImage || siteInfo.seo.ogImage)
  : `${siteUrl}${ogImage || siteInfo.seo.ogImage}`;
const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;

const serviceJsonLd = serviceSchema ? {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: serviceSchema.name,
  description: serviceSchema.description,
  serviceType: serviceSchema.serviceType,
  provider: {
    '@type': business.schemaType,
    name: siteInfo.name,
    telephone: schemaData.telephone,
    email: schemaData.email,
    address: {
      '@type': 'PostalAddress',
      streetAddress: schemaData.address.streetAddress,
      addressLocality: schemaData.address.addressLocality,
      postalCode: schemaData.address.postalCode,
      addressRegion: schemaData.address.addressRegion,
      addressCountry: schemaData.address.addressCountry,
    },
  },
  areaServed: serviceSchema.areaServed?.map((name) => ({ '@type': 'City', name })) ?? [
    { '@type': 'City', name: 'Metz' },
    { '@type': 'City', name: 'Nancy' },
  ],
  url: canonicalUrl,
} : null;
---

<!DOCTYPE html>
<html lang={siteInfo.lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="format-detection" content="telephone=no" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {indexable ? (
    <>
      <meta name="robots" content="index, follow" />
      <link rel="canonical" href={canonicalUrl} />
    </>
  ) : (
    <meta name="robots" content="noindex, nofollow" />
  )}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta name="theme-color" content="#2D4B4E" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content={siteInfo.name} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Polices critiques -->
  <link rel="preload" href="/fonts/lora-v37-latin-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-sans-v17-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-sans-v17-latin-600.woff2" as="font" type="font/woff2" crossorigin />

  {heroImage && <link rel="preload" as="image" href={heroImage} />}

  <!-- Schema.org WebPage (minimal, pas LocalBusiness pour eviter conflits) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": title,
    "description": description,
    "inLanguage": siteInfo.lang,
    "isPartOf": {
      "@type": "WebSite",
      "name": siteInfo.name,
      "url": siteUrl,
    },
  })}></script>

  {serviceJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)}></script>
  )}

  <style>
    @font-face { font-family: 'Lora'; font-style: normal; font-weight: 700; font-display: swap; src: url('/fonts/lora-v37-latin-700.woff2') format('woff2'); }
    @font-face { font-family: 'DM Sans'; font-style: normal; font-weight: 400; font-display: swap; src: url('/fonts/dm-sans-v17-latin-regular.woff2') format('woff2'); }
    @font-face { font-family: 'DM Sans'; font-style: normal; font-weight: 600; font-display: swap; src: url('/fonts/dm-sans-v17-latin-600.woff2') format('woff2'); }
  </style>
</head>
<body class="bg-neutral-50 text-neutral-800 font-body antialiased">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-accent-700 focus:text-white focus:px-4 focus:py-2 focus:rounded">
    Aller au contenu principal
  </a>

  <!-- Header minimal : logo + tel uniquement -->
  <header class="bg-white border-b border-neutral-200 py-3">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label={siteInfo.name}>
        <img src="/images/logo-sm.webp" alt={siteInfo.name} class="h-10 w-auto" width="40" height="40" />
        <span class="font-heading font-semibold text-primary-900 hidden sm:inline">{siteInfo.name}</span>
      </a>
      <a
        href={`tel:${siteInfo.phone}`}
        class="inline-flex items-center gap-2 text-primary-900 font-semibold hover:text-accent-700 transition-colors text-sm sm:text-base"
        aria-label={`Appeler ${siteInfo.phoneDisplay}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        <span>{siteInfo.phoneDisplay}</span>
      </a>
    </div>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <!-- Footer minimal : mentions légales uniquement -->
  <footer class="bg-primary-900 text-neutral-100 py-8 mt-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-sm text-center space-y-2">
      <p>{siteInfo.name} · {siteInfo.address.city} {siteInfo.address.postalCode}</p>
      <div class="flex justify-center gap-4 text-neutral-300">
        <a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a>
        <span>·</span>
        <a href="/politique-confidentialite" class="hover:text-white transition-colors">Politique de confidentialité</a>
        {ads.enabled && (
          <>
            <span>·</span>
            <button
              type="button"
              onclick="typeof window.openConsentSettings === 'function' && window.openConsentSettings()"
              class="hover:text-white transition-colors bg-transparent border-0 p-0 cursor-pointer text-inherit"
            >
              Gérer mes cookies
            </button>
          </>
        )}
      </div>
    </div>
  </footer>

  <!-- Umami Analytics (cookieless) -->
  <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="96fd46e0-47fa-4c79-abda-447fa79bd0f4" crossorigin="anonymous"></script>

  {ads.enabled && ads.conversionId && (
    <>
      <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'granted',
          wait_for_update: 500,
        });
      </script>
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ads.conversionId}`}></script>
      <script is:inline define:vars={{ conversionId: ads.conversionId, adsConversionId: ads.adsConversionId }}>
        gtag('js', new Date());
        gtag('config', conversionId);
        if (adsConversionId) gtag('config', adsConversionId);
      </script>
      <ConsentBanner />
    </>
  )}
</body>
</html>
